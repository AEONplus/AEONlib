    <!-- +++++++++++ -:RssFabryPerotMode:- +++++++++++ -->
    <xs:simpleType name="RssFabryPerotMode">
        <xs:annotation>
            <xs:documentation>
                The available configurations are TF (tunable filter), LR (low resolution),
                MR (medium resolution) and HR (high resolution).
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="TF"/>
            <xs:enumeration value="LR"/>
            <xs:enumeration value="MR"/>
            <xs:enumeration value="HR"/>
            <xs:enumeration value="None"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssEtalonPattern:- +++++++++++ -->
    <xs:complexType name="RssEtalonPattern">
        <xs:annotation>
            <xs:documentation>
                A list of wavelength ranges or wavelengths for etalon positions.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" name="Wavelength" type="RssEtalonWavelength"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssEtalonWavelength:- +++++++++++ -->
    <xs:complexType name="RssEtalonWavelength">
        <xs:sequence>
            <xs:element name="Value">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="4300"/>
                        <xs:maxInclusive value="9000"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="angstroms" name="Units" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssDetMode:- +++++++++++ -->
    <xs:simpleType name="RssDetMode">
        <xs:annotation>
            <xs:documentation>Describes the readout modes</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Normal"/>
            <xs:enumeration value="Frame Transfer"/>
            <xs:enumeration value="Shuffle"/>
            <xs:enumeration value="Slot Mode"/>
            <xs:enumeration value="Drift Scan"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- =========== HRS PHASE 1 =========== -->

    <!-- +++++++++++ -:P1Hrs:- +++++++++++ -->
    <xs:complexType name="P1Hrs">
        <xs:annotation>
            <xs:documentation>
                An HRS setup.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Mode" type="HrsMode"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== HRS PHASE 2 =========== -->

    <!-- +++++++++++ -:Hrs:- +++++++++++ -->
    <xs:complexType name="Hrs">
        <xs:annotation>
            <xs:documentation>
                An HRS setup.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="HrsConfig" type="HrsConfig"/>
            <xs:element name="HrsProcedure" type="HrsProcedure"/>
            <xs:element name="HrsBlueDetector" type="HrsDetector"/>
            <xs:element name="HrsRedDetector" type="HrsDetector"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:HrsDetector:- +++++++++++ -->
    <xs:complexType name="HrsDetector">
        <xs:annotation>
            <xs:documentation>
                An HRS detector setup.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Iterations" type="Iterations"/>
            <xs:element name="ReadoutSpeed" type="HrsReadoutSpeed"/>
            <xs:element name="NumberOfAmplifiers">
                <xs:annotation>
                    <xs:documentation>
                        The number of amplifiers to use when reading out the CCD.
                    </xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:maxInclusive value="4"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="PreBinRows">
                <xs:annotation>
                    <xs:documentation>Combine this many CCD rows during readout</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                        <xs:maxInclusive value="9"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="PreBinCols">
                <xs:annotation>
                    <xs:documentation>Combine this many CCD columns during readout</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                        <xs:maxInclusive value="9"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="PreShuffle" type="xs:unsignedInt"/>
            <xs:element name="PostShuffle" type="xs:unsignedInt"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:HrsReadoutSpeed:- +++++++++++ -->
    <xs:simpleType name="HrsReadoutSpeed">
        <xs:annotation>
            <xs:documentation>The readout speed. Faster readouts have more noise.
                <ul>
                    <li>None - don't do a readout.</li>
                    <li>Slow - do a low noise, slow readout.</li>
                    <li>Fast - do a higher noise, faster readout.</li>
                </ul>
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="None"/>
            <xs:enumeration value="Slow"/>
            <xs:enumeration value="Fast"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:HrsConfig:- +++++++++++ -->
    <xs:complexType name="HrsConfig">
        <xs:annotation>
            <xs:documentation>
                Configuration of the HRS.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Mode" type="HrsMode"/>
            <xs:element name="ExposureType" type="HrsExposureType"/>
            <xs:element minOccurs="0" name="NodAndShuffle" type="HrsNodAndShuffle"/>
            <xs:element name="IodineCellPosition" type="HrsIodineCellPosition"/>
            <xs:element name="TargetLocation" type="HrsTargetLocation"/>
            <xs:element name="FibreSeparation" type="HrsFibreSeparation"/>
            <xs:element name="UseThArWithIodineCell" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation>
                        Whether an exposure with the ThAr lamp should be done in addition to the one
                        with the iodine cell. This is only relevant if the iodine cell is used , i.e.
                        if the value of the IodineCellPosition element is IN.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:HrsExposureType:- +++++++++++ -->
    <xs:simpleType name="HrsExposureType">
        <xs:annotation>
            <xs:documentation>
                Exposure type.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Arc"/>
            <xs:enumeration value="Bias"/>
            <xs:enumeration value="Dark"/>
            <xs:enumeration value="Flat Field"/>
            <xs:enumeration value="Science"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:HrsNodAndShuffle:- +++++++++++ -->
    <xs:complexType name="HrsNodAndShuffle">
        <xs:annotation>
            <xs:documentation>
                A nod and shuffle setting.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="NodInterval">
                <xs:annotation>
                    <xs:documentation>
                        The time per nod interval.
                    </xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Value">
                            <xs:simpleType>
                                <xs:restriction base="xs:unsignedInt">
                                    <xs:minExclusive value="0"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element fixed="Seconds" name="Units" type="xs:string"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="NodCount" type="Iterations">
                <xs:annotation>
                    <xs:documentation>
                        The number of nods required.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:HrsIodineCellPosition:- +++++++++++ -->
    <xs:simpleType name="HrsIodineCellPosition">
        <xs:annotation>
            <xs:documentation>
                Iodine cell position.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="OUT"/>
            <xs:enumeration value="IN"/>
            <xs:enumeration value="ThAr"/>
            <xs:enumeration value="CALIBRATION"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:HrsTargetLocation:- +++++++++++ -->
    <xs:simpleType name="HrsTargetLocation">
        <xs:annotation>
            <xs:documentation>
                Target location.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Star"/>
            <xs:enumeration value="Bisect"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:HrsFibreSeparation:- +++++++++++ -->
    <xs:complexType name="HrsFibreSeparation">
        <xs:annotation>
            <xs:documentation>Fibre separation in arcseconds</xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Value">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="16"/>
                        <xs:maxInclusive value="120"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="seconds" name="Units" type="xs:string"/>
        </xs:all>

    </xs:complexType>

    <!-- +++++++++++ -:HrsProcedure:- +++++++++++ -->
    <xs:complexType name="HrsProcedure">
        <xs:annotation>
            <xs:documentation>
                A procedure.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Cycles" type="Iterations"/>
            <xs:element name="BlueExposurePattern" type="HrsExposurePattern"/>
            <xs:element name="RedExposurePattern" type="HrsExposurePattern"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:HrsExposurePattern:- +++++++++++ -->
    <xs:complexType name="HrsExposurePattern">
        <xs:annotation>
            <xs:documentation>
                An exposure pattern.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="ExposureTime" type="ExposureTime"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:HrsCalibration:- +++++++++++ -->
    <xs:complexType name="HrsCalibration">
        <xs:annotation>
            <xs:documentation>An HRS calibration.</xs:documentation>
        </xs:annotation>
    </xs:complexType>

    <!-- +++++++++++ -:HrsCalibrationSetup:- +++++++++++ -->
    <xs:complexType name="HrsCalibrationSetup">
        <xs:annotation>
            <xs:documentation>An HRS calibration setup defined outside an HRS setup.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" name="Hrs" type="Hrs"/>
            <xs:element name="HrsCalibration" type="HrsCalibration"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== HRS SHARED =========== -->

    <!-- +++++++++++ -:HrsMode:- +++++++++++ -->
    <xs:simpleType name="HrsMode">
        <xs:annotation>
            <xs:documentation>
                HRS mode.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="LOW RESOLUTION"/>
            <xs:enumeration value="MEDIUM RESOLUTION"/>
            <xs:enumeration value="HIGH RESOLUTION"/>
            <xs:enumeration value="HIGH STABILITY"/>
            <xs:enumeration value="INT CAL FIBRE"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- =========== NIRWALS PHASE 1 =========== -->

    <!-- +++++++++++ -:P1Nir:- +++++++++++ -->
    <xs:complexType name="P1Nir">
        <xs:annotation>
            <xs:documentation>
                NIR setup.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Grating" type="NirGrating"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== NIRWALS PHASE 2 =========== -->

    <!-- +++++++++++ -:Nir:- +++++++++++ -->
    <xs:complexType name="Nir">
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Cycles" type="Iterations"/>
            <xs:element name="NirProcedure" type="NirProcedure"/>
            <xs:element name="NirConfig" type="NirConfig"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="NirCalibration" type="NirCalibration"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="NirNonChargedCalibration" type="NirCalibration"/>
            <xs:element name="InCalibration" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation>This states whether the NIRWALS setup is a (nighttime) calibration.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:NirSampling:- +++++++++++ -->
    <xs:simpleType name="NirSampling">
        <xs:annotation>
            <xs:documentation>
                NIR sampling options.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Fowler"/>
            <xs:enumeration value="Up-the-Ramp Group"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirGain:- +++++++++++ -->
    <xs:simpleType name="NirGain">
        <xs:annotation>
            <xs:documentation>
                Gain setting.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Bright"/>
            <xs:enumeration value="Faint"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirDetector:- +++++++++++ -->
    <xs:complexType name="NirDetector">
        <xs:annotation>
            <xs:documentation>
                NIR detector setup.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="ExposureTime" type="ExposureTime"/>
            <xs:element name="Iterations" type="Iterations"/>
            <xs:element name="Gain" type="NirGain"/>
            <xs:element name="Sampling" type="NirSampling"/>
            <xs:element name="Reads">
                <xs:annotation>
                    <xs:documentation>How many reads are done for each sample. For Fowler this is how many reads are done at the beginning and at the end. For Up-the-Ramp Group this is how many reads you do at each sample (group) up the ramp.</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Ramps">
                <xs:annotation>
                    <xs:documentation>The number of samples up the ramp for Up-the-Ramp Group mode.</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Groups">
                <xs:annotation>
                    <xs:documentation>The number of samples up the ramp for Up-the-Ramp Group mode.</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:NirGratingAngle:- +++++++++++ -->
    <xs:complexType name="NirGratingAngle">
        <xs:annotation>
            <xs:documentation>
                The grating can be rotated to any angle between 0 and 50 degrees.
            </xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Value">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0"/>
                        <xs:maxInclusive value="50"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="degrees" name="Units" type="xs:string"/>
        </xs:all>
    </xs:complexType>


<?xml version="1.0" encoding="UTF-8" standalone="no"?><xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:cxs="http://www.w3.org/2001/XMLSchema" attributeFormDefault="unqualified" elementFormDefault="qualified">

    <!-- =========== PROPOSAL PHASE 1 =========== -->

    <!-- +++++++++++ -:P1Proposal:- +++++++++++ -->
    <xs:complexType name="P1Proposal">
        <xs:annotation>
            <xs:documentation>The root node of a SALT proposal.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="ProposalType" type="ProposalType"/>
            <xs:element name="Title" type="xs:string">
                <xs:annotation>
                    <xs:documentation>The title of the proposal.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Abstract" type="xs:string">
                <xs:annotation>
                    <xs:documentation>A text based version of the abstract.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Year" type="xs:unsignedInt"/>
            <xs:element name="Semester">
                <xs:simpleType>
                    <xs:annotation>
                        <xs:documentation>
                            The semester.

                            1: 1 May to 31 October
                            2: 1 November to 30 April
                        </xs:documentation>
                    </xs:annotation>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:enumeration value="1"/>
                        <xs:enumeration value="2"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="1" name="Phase" type="xs:unsignedInt">
                <xs:annotation>
                    <xs:documentation>1 = Request for time.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Partners" type="Partners"/>
            <xs:element name="Investigators" type="Investigators"/>
            <xs:element minOccurs="0" name="SouthAfricanRole" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        The role played by the South African investigators.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element minOccurs="0" name="HasAfricanPI" type="HasAfricanPI"/>
            <xs:element maxOccurs="unbounded" name="TimeRequest" type="P1TimeRequest"/>
            <xs:sequence minOccurs="0">
                <!-- Science and Science Verification -->
                <xs:element name="ScientificJustification" type="ScientificJustification"/>
                <xs:element minOccurs="0" name="TargetOfOpportunity" type="P1TargetOfOpportunity">
                    <xs:annotation>
                        <xs:documentation>For targets of opportunity. Act on alert authorisation.
                        </xs:documentation>
                    </xs:annotation>
                </xs:element>
                <xs:element default="false" name="TimeCritical" type="xs:boolean">
                    <xs:annotation>
                        <xs:documentation>
                            Flag indicating whether the proposal contains a time critical
                            observation.
                        </xs:documentation>
                    </xs:annotation>
                </xs:element>
                <xs:element default="false" name="Priority4Proposal" type="xs:boolean">
                    <xs:annotation>
                        <xs:documentation>
                            Flag indicating whether the proposal is a Priority 4 proposal.
                        </xs:documentation>
                    </xs:annotation>
                </xs:element>
                <xs:element name="Targets" type="Targets"/>
                <xs:element name="Observations">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="ObservingConditions" type="P1ObservingConditions"/>
                            <xs:element maxOccurs="unbounded" minOccurs="0" name="Observation" type="P1Observation"/>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
                <xs:element name="InstrumentConfigurations">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element maxOccurs="unbounded" name="InstrumentConfiguration" type="P1InstrumentConfiguration"/>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
                <xs:element minOccurs="0" name="ExternalFunding" type="ExternalFunding"/>
                <xs:element maxOccurs="unbounded" minOccurs="0" name="PreviousProposal" type="PreviousProposal"/>
                <xs:element name="Outreach" type="Outreach"/>
            </xs:sequence>
        </xs:sequence>
        <xs:attribute fixed="6.1" name="SchemaVersion" type="SchemaVersion" use="required"/>
        <xs:attribute name="code" type="ProposalCode"/>
        <xs:attribute default="true" name="final" type="xs:boolean" use="optional"/>
        <xs:attribute name="PrincipalInvestigator" type="xs:string" use="optional"/>
        <xs:attribute name="PrincipalContact" type="xs:string" use="optional"/>
    </xs:complexType>

    <xs:simpleType name="SchemaVersion">
        <xs:restriction base="xs:string">
            <xs:pattern value="6\.1"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:P1TargetOfOpportunity:- +++++++++++ -->
    <xs:complexType name="P1TargetOfOpportunity">
        <xs:sequence>
            <xs:element name="Reason" type="xs:string"/>
            <xs:element name="Instruments">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element maxOccurs="unbounded" name="Instrument" type="xs:string"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:P1ObservingConditions:- +++++++++++ -->
    <xs:complexType name="P1ObservingConditions">
        <xs:sequence>
            <xs:element name="Transparency" type="Transparency"/>
            <xs:element name="MaximumSeeing" type="SeeingValue"/>
            <xs:element name="Description" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:P1Observation:- +++++++++++ -->
    <xs:complexType name="P1Observation">
        <xs:sequence>
            <xs:element name="TargetRef" type="xs:string"/>
            <xs:element name="ObservingTime">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Value" type="xs:unsignedInt"/>
                        <xs:element fixed="seconds" name="Units" type="xs:string"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element default="1" name="Visits">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="MaximumLunarPhase" type="MaximumLunarPhase"/>
            <xs:element name="Ranking" type="Ranking"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:P1InstrumentConfiguration:- +++++++++++ -->
    <xs:complexType name="P1InstrumentConfiguration">
        <xs:sequence>
            <xs:choice>
                <xs:element name="Salticam" type="P1Salticam"/>
                <xs:element name="Rss" type="P1Rss"/>
                <xs:element name="Hrs" type="P1Hrs"/>
                <xs:element name="Nir" type="P1Nir"/>
                <xs:element name="Bvit" type="P1Bvit"/>
            </xs:choice>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="InstrumentSimulation" type="InstrumentSimulation"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:P1TimeRequest:- +++++++++++ -->
    <xs:complexType name="P1TimeRequest">
        <xs:annotation>
            <xs:documentation>
                The time request for a semester.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Year" type="xs:unsignedInt"/>
            <xs:element name="Semester">
                <xs:simpleType>
                    <xs:annotation>
                        <xs:documentation>
                            The semester.

                            1: 1 May to 31 October
                            2: 1 November to 30 April
                        </xs:documentation>
                    </xs:annotation>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:enumeration value="1"/>
                        <xs:enumeration value="2"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="TotalRequestedTime" type="ExposureTime"/>
            <xs:element name="MinimumUsefulTime" type="ExposureTime"/>
            <xs:element minOccurs="0" name="Comments" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:P1BasicDetails:- +++++++++++ -->
    <xs:complexType name="P1BasicDetails">
        <xs:annotation>
            <xs:documentation>
                Basic details required for a DDT, commissioning or engineering proposal.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Title" type="xs:string">
                <xs:annotation>
                    <xs:documentation>The title of the proposal.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Abstract" type="xs:string"/>
            <xs:element name="TotalRequestedTime" type="ExposureTime">
                <xs:annotation>
                    <xs:documentation>
                        The total requested time for this proposal.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Partners" type="Partners"/>
            <xs:element name="Investigators" type="Investigators"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== PROPOSAL PHASE 2 =========== -->

    <!-- +++++++++++ -:Proposal:- +++++++++++ -->
    <xs:complexType name="Proposal">
        <xs:annotation>
            <xs:documentation>The root node of a SALT proposal.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="ProposalType" type="ProposalType"/>
            <xs:element maxOccurs="unbounded" name="ProposalSemester" type="ProposalSemester"/>
            <xs:element minOccurs="0" name="ScientificJustification" type="ScientificJustification"/>
            <xs:element name="Year" type="xs:unsignedInt"/>
            <xs:element name="Semester" type="Semester"/>
            <xs:element fixed="2" name="Phase" type="xs:unsignedInt">
                <xs:annotation>
                    <xs:documentation>2 = Detailed telescope configuration.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element minOccurs="0" name="TargetOfOpportunity" type="TargetOfOpportunity"/>
            <xs:element minOccurs="0" name="ExternalFunding" type="ExternalFunding"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="PreviousProposal" type="PreviousProposal"/>
            <xs:element minOccurs="0" name="ProprietaryPeriod">
                <xs:annotation>
                    <xs:documentation>
                        The period for which the data remains proprietary to the investigators.
                    </xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Months" type="xs:unsignedInt"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element minOccurs="0" name="Partners" type="Partners"/>
            <xs:element minOccurs="0" name="Investigators" type="Investigators"/>
            <xs:element minOccurs="0" name="HasAfricanPI" type="HasAfricanPI"/>
            <xs:element name="Targets" type="Targets"/>
            <xs:element minOccurs="0" name="BlockCodes">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element maxOccurs="unbounded" minOccurs="0" name="BlockCode" type="BlockCode"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element minOccurs="0" name="Phase1Info" type="Phase1Info"/>
            <xs:element name="Detail">
                <xs:annotation>
                    <xs:documentation>
                        Several elements (namely SubBlock, SubSubBlock, Pointing, TelescopeConfig and PayloadConfig
                        elements may or may not be shown in a GUI representation of the proposal. The
                        RequiredElements element states which of these elements have to be shown as they are
                        syntactically required. The RequestedElements element, on the other hand, states which
                        elements should be shown irrespective of whether they are necessary from a syntactic point
                        of view.
                    </xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="RequiredElements" type="DetailInformation"/>
                        <xs:element name="RequestedElements" type="DetailInformation"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
        <xs:attribute fixed="6.1" name="SchemaVersion" type="xs:string" use="required"/>
        <xs:attribute name="code" type="ProposalCode"/>
        <xs:attribute default="true" name="final" type="xs:boolean" use="optional"/>
        <xs:attribute name="PrincipalInvestigator" type="xs:string" use="optional"/>
        <xs:attribute name="PrincipalContact" type="xs:string" use="optional"/>
    </xs:complexType>

    <!-- +++++++++++ -:ProposalSemester:- +++++++++++ -->
    <xs:complexType name="ProposalSemester">
        <xs:annotation>
            <xs:documentation>The semester-specific proposal details.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Year" type="xs:unsignedInt"/>
            <xs:element name="Semester" type="Semester"/>
            <xs:element name="Title" type="xs:string">
                <xs:annotation>
                    <xs:documentation>The title of the proposal.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Abstract" type="xs:string">
                <xs:annotation>
                    <xs:documentation>A text based version of the abstract.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ReadMe" type="xs:string"/>
            <xs:element name="Outreach" type="Outreach"/>
            <xs:element minOccurs="0" name="NightlogSummary" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        A short phrase describing the science for the nightlog summary. Examples would be "Study of the
                        properties of thin and thick disks of galaxy IC2531" or "Tracing the history of LIRGs".
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="TimeTransfer" type="TimeTransfer"/>
            <xs:element name="Pools">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element maxOccurs="unbounded" minOccurs="0" name="Pool" type="Pool"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="Blocks">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element maxOccurs="unbounded" minOccurs="0" name="Block" type="Block"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element minOccurs="0" name="TimeAllocations">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element maxOccurs="unbounded" minOccurs="0" name="TimeAllocation" type="TimeAllocation"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element minOccurs="0" name="BlockVisits">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element maxOccurs="unbounded" minOccurs="0" name="BlockVisit" type="BlockVisit"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Semester:- +++++++++++ -->
    <xs:simpleType name="Semester">
        <xs:annotation>
            <xs:documentation>
                The semester.

                1: 1 May to 31 October
                2: 1 November to 30 April
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:unsignedInt">
            <xs:minInclusive value="1"/>
            <xs:maxInclusive value="2"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:TargetOfOpportunity:- +++++++++++ -->
    <xs:complexType name="TargetOfOpportunity">
        <xs:annotation>
            <xs:documentation>For targets of opportunity. Act on alert authorisation.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Reason" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:PayloadConfig:- +++++++++++ -->
    <xs:complexType name="PayloadConfig">
        <xs:annotation>
            <xs:documentation>A payload configuration is mainly used to cope with the situation where a
                pellicle setup is being used. It is a rather simple matter to cope with a single instrument
                being used at a time. The complexity comes in when two instruments are used concurrently.
                With the pellicle setup the primary instrument is always SALTICAM. The fold mirrors allow
                one other payload port to be used. So we can use SALTICAM and RSS or SALTICAM and FIF
                (Fibre Instrument Feed) or SALTICAM and the auxilliary port.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Type" type="PayloadConfigType"/>
            <xs:element name="GuideMethod" type="GuideMethod"/>
            <xs:element default="false" name="PellicleConfig" type="xs:boolean"/>
            <xs:element default="true" name="WaitOnOtherInstrument" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation>
                        If true for a pellicle setup, the next step starts only after both instruments
                        have finished with the current configuration. In case of no pellicle setup the
                        value of this element is irrelevant.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:choice maxOccurs="unbounded">
                <xs:element name="Salticam" type="Salticam"/>
                <xs:element name="Rss" type="Rss"/>
                <xs:element name="Hrs" type="Hrs"/>
                <xs:element name="Nir" type="Nir"/>
                <xs:element name="Bvit" type="Bvit"/>
            </xs:choice>
            <xs:element minOccurs="0" name="CalibrationFilter" type="CalibrationFilter"/>
            <xs:element minOccurs="0" name="NeutralDensityPercent">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:maxInclusive value="100"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:PayloadConfigType:- +++++++++++ -->
    <xs:simpleType name="PayloadConfigType">
        <xs:annotation>
            <xs:documentation>The type of this payload configuration.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Acquisition"/>
            <xs:enumeration value="Instrument Acquisition"/>
            <xs:enumeration value="Science"/>
            <xs:enumeration value="Nighttime Calibration"/>
            <xs:enumeration value="Daytime Calibration"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:GuideMethod:- +++++++++++ -->
    <xs:simpleType name="GuideMethod">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Default"/>
            <!--<xs:enumeration value="Manual"/>-->
            <xs:enumeration value="RSS Probe"/>
            <!--<xs:enumeration value="Slitviewer"/>
          <xs:enumeration value="QUACK"/> -->
            <xs:enumeration value="SALTICAM"/>
            <xs:enumeration value="SALTICAM Probe"/>
            <xs:enumeration value="HRS Probe"/>
            <!--<xs:enumeration value="Science Target"/>-->
            <xs:enumeration value="None"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:CalibrationFilter:- +++++++++++ -->
    <xs:simpleType name="CalibrationFilter">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Red and Clear"/>
            <xs:enumeration value="Blue and Red"/>
            <xs:enumeration value="UV and Blue"/>
            <xs:enumeration value="Clear and UV"/>
            <xs:enumeration value="ND and Clear"/>
            <xs:enumeration value="Clear and ND"/>
            <xs:enumeration value="None"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:TelescopeConfig:- +++++++++++ -->
    <xs:complexType name="TelescopeConfig">
        <xs:annotation>
            <xs:documentation>The main purpose of the TelescopeConfig element is to group PayloadConfig elements
                together.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element default="1" name="Iterations" type="Iterations"/>
            <xs:element minOccurs="0" name="OnSkyPositionAngle">
                <xs:annotation>
                    <xs:documentation>Position angle of the camera. Degrees from north (being zero) clockwise
                        for positive angle
                    </xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:choice>
                        <xs:sequence>
                            <xs:element name="Value" type="xs:double"/>
                            <xs:element fixed="degrees" minOccurs="0" name="Units" type="xs:string"/>
                            <xs:element minOccurs="0" name="Fixed" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>A fixed position angle must not be flipped by 180 degrees.
                                    </xs:documentation>
                                </xs:annotation>
                            </xs:element>
                        </xs:sequence>
                        <xs:element name="UseParallacticAngle">
                            <xs:simpleType>
                                <xs:restriction base="xs:string">
                                    <xs:enumeration value=""/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                    </xs:choice>
                </xs:complexType>
            </xs:element>
            <xs:element minOccurs="0" name="GuideStar">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Coordinates" type="Coordinates"/>
                        <xs:element name="Magnitude" type="xs:double"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element maxOccurs="unbounded" name="PayloadConfig" type="PayloadConfig"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:TimeRestriction:- +++++++++++ -->
    <xs:complexType name="TimeRestriction">
        <xs:annotation>
            <xs:documentation>A time restriction for an observation.
            </xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="TimeStart" type="xs:dateTime"/>
            <xs:element name="TimeEnd" type="xs:dateTime"/>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:PhaseConstraint:- +++++++++++ -->
    <xs:complexType name="PhaseConstraint">
        <xs:annotation>
            <xs:documentation>A phase constraint cannot be defined without first defining an Ephemeris in
                the referenced Target.
            </xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="PhaseStart">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0.0"/>
                        <xs:maxInclusive value="1.0"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="PhaseEnd">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0.0"/>
                        <xs:maxInclusive value="1.0"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:SeeingConstraint:- +++++++++++ -->
    <xs:complexType name="SeeingConstraint">
        <xs:annotation>
            <xs:documentation>Describes what seeing conditions are acceptable (in arcsecs).
            </xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Maximum" type="SeeingValue"/>
            <xs:element minOccurs="0" name="Minimum" type="SeeingValue">
            </xs:element>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:Acquisition:- +++++++++++ -->
    <xs:complexType name="Acquisition">
        <xs:annotation>
            <xs:documentation>An acquisition for an observation, including a target, an acquisition telescope
                configuration and, optionally, a reference star on which to acquire.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:choice>
                <xs:element name="TargetRef" type="xs:string"/>
                <xs:element name="Target" type="Target"/>
            </xs:choice>
            <xs:element minOccurs="0" name="BlindOffset">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Coordinates" type="Coordinates"/>
                        <xs:element name="Magnitude" type="xs:double"/>
                        <xs:element name="NorthOffset">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="Value" type="xs:double"/>
                                    <xs:element fixed="arcseconds" name="Units" type="xs:string"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="EastOffset">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="Value" type="xs:double"/>
                                    <xs:element fixed="arcseconds" name="Units" type="xs:string"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="TelescopeConfig" type="TelescopeConfig"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="FindingChart" type="FindingChart"/>
            <xs:element minOccurs="0" name="ReferenceStar" type="ReferenceStar"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:ReferenceStar:- +++++++++++ -->
    <xs:complexType name="ReferenceStar">
        <xs:annotation>
            <xs:documentation>The reference star to use for an acquisition.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="RightAscension" type="Angle"/>
            <xs:element name="Declination" type="Angle"/>
            <xs:element name="Equinox" type="xs:double"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Observation:- +++++++++++ -->
    <xs:complexType name="Observation">
        <xs:annotation>
            <xs:documentation>An acquisition and a list of telescope configurations.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Acquisition" type="Acquisition"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="TelescopeConfig" type="TelescopeConfig"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="PhaseConstraint" type="PhaseConstraint"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="TimeRestriction" type="TimeRestriction"/>
            <xs:element name="PipelineConfig" type="PipelineConfig"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Pointing:- +++++++++++ -->
    <xs:complexType name="Pointing">
        <xs:annotation>
            <xs:documentation>All the information required for a single track observation. In general, this will be a
                single Observation. However, if several targets in the same field of view are considered (e.g., three
                stars in a cluster), more than one Observation might be included.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element maxOccurs="unbounded" name="Observation" type="Observation"/>
            <xs:element minOccurs="0" name="MinimumUsefulTime" type="ExposureTime"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Block:- +++++++++++ -->
    <xs:complexType name="Block">
        <xs:sequence>
            <xs:element minOccurs="0" name="IntendedFor" type="IntendedFor"/>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="BlockCode" type="xs:string"/>
            <xs:element default="1" name="Visits">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element minOccurs="0" name="Wait" type="Wait"/>
            <xs:element minOccurs="0" name="Comments" type="xs:string"/>
            <xs:element name="Priority" type="Priority"/>
            <xs:element name="Ranking" type="Ranking"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="InPool">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="PoolCode" type="xs:string"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="BlockType" type="BlockType"/>
            <xs:element name="Charged" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation>Whether this block is charged for.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Transparency" type="Transparency"/>
            <xs:element minOccurs="0" name="Moon" type="Moon"/>
            <xs:element name="MaximumLunarPhase" type="MaximumLunarPhase"/>
            <xs:element name="MinimumLunarAngularDistance">
                <xs:annotation>
                    <xs:documentation>
                        The minimum angular distance between the Moon and the target.
                    </xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:all>
                        <xs:element name="Value">
                            <xs:simpleType>
                                <xs:restriction base="xs:double">
                                    <xs:minInclusive value="0"/>
                                    <xs:maxInclusive value="180"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element fixed="degrees" name="Units" type="xs:string"/>
                    </xs:all>
                </xs:complexType>
            </xs:element>
            <xs:element name="SeeingConstraint" type="SeeingConstraint"/>
            <xs:element minOccurs="0" name="MaxVisits" type="xs:unsignedInt">
                <xs:annotation>
                    <xs:documentation>
                        The maximum number of visits for all semesters together.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element minOccurs="0" name="ContinuousVisit">
                <xs:annotation>
                    <xs:documentation>
                        Treat the visits as a single continuous visits, i.e. do them all consecutively without any
                        wait time between them.
                    </xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:enumeration value=""/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element minOccurs="0" name="ExpiryDate" type="xs:dateTime"/>
            <xs:element maxOccurs="unbounded" name="SubBlock" type="SubBlock"/>
        </xs:sequence>
        <xs:attribute name="notForObserving" type="xs:boolean" use="optional"/>
        <xs:attribute fixed="6.1" name="SchemaVersion" type="SchemaVersion" use="required"/>
    </xs:complexType>

    <!-- +++++++++++ -:BlockType:- +++++++++++ -->
    <xs:simpleType name="BlockType">
        <xs:annotation>
            <xs:documentation>
                The block type, such as "Science".
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Science"/>
            <xs:enumeration value="Calibration"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:Priority:- +++++++++++ -->
    <xs:simpleType name="Priority">
        <xs:annotation>
            <xs:documentation>
                Specifies the priority of the time when this block should
                be observed.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:int">
            <xs:minInclusive value="0"/>
            <xs:maxInclusive value="4"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:Wait:- +++++++++++ -->
    <xs:complexType name="Wait">
        <xs:annotation>
            <xs:documentation>
                The number of days to wait between each visit to this block.
            </xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Value">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="days" name="Units" type="xs:string"/>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:SubBlock:- +++++++++++ -->
    <xs:complexType name="SubBlock">
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element default="1" name="Iterations" type="Iterations"/>
            <xs:element maxOccurs="unbounded" name="SubSubBlock" type="SubSubBlock"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:SubSubBlock:- +++++++++++ -->
    <xs:complexType name="SubSubBlock">
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element default="1" name="Iterations" type="Iterations"/>
            <xs:element maxOccurs="unbounded" name="Pointing" type="Pointing"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:PipelineConfig:-+++++++++++ -->
    <xs:complexType name="PipelineConfig">
        <xs:annotation>
            <xs:documentation>
                Configuration information required for the data reduction pipeline.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element default="Normal" name="Notification" type="Notification"/>
            <xs:element default="HTML" name="ReductionDocumentationFormat" type="ReductionDocumentationFormat"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Notification:- +++++++++++ -->
    <xs:simpleType name="Notification">
        <xs:annotation>
            <xs:documentation>
                Allows the PI to choose when to be notified that an observation has been done.
                The following options exist:
                1) Normal: The PI is notified by email when the raw and reduced data from a night is ready
                for retrieval from the ftp server.
                2) Fast: After a night of observations, the individual raw data files are immediately made
                available for download and the PI is notified by email that the data is available.
                3) User: he user will download the data from the web manager. The PI will be notified when
                new raw and reduced data is accessible via the web manager.
                4) Complete: The PI will be notified when the observations for the proposal are complete and
                all data is available for download.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Normal"/>
            <xs:enumeration value="Fast"/>
            <xs:enumeration value="User"/>
            <xs:enumeration value="Complete"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:ReductionDocumentationFormat:- +++++++++++ -->
    <xs:simpleType name="ReductionDocumentationFormat">
        <xs:annotation>
            <xs:documentation>
                The format for the reduction documentation.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="HTML"/>
            <xs:enumeration value="ASCII"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:Pool:- +++++++++++ -->
    <xs:complexType name="Pool">
        <xs:annotation>
            <xs:documentation>
                A pool of Blocks.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="PoolCode" type="xs:string"/>
            <xs:element name="PoolType" type="PoolType"/>
            <xs:element maxOccurs="unbounded" name="PoolRule" type="PoolRule"/>
            <xs:element maxOccurs="unbounded" name="PriorityMoonTime">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Priority" type="Priority"/>
                        <xs:element name="Moon" type="Moon"/>
                        <xs:element name="RequestedTime" type="ExposureTime"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:PoolType:- +++++++++++ -->
    <xs:simpleType name="PoolType">
        <xs:annotation>
            <xs:documentation>
                The pool type, such as "Science".
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Science"/>
            <xs:enumeration value="Calibration"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:PoolRule:- +++++++++++ -->
    <xs:complexType name="PoolRule">
        <xs:annotation>
            <xs:documentation>A pool rule.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="PoolRuleFunction" type="PoolRuleFunction"/>
            <xs:element minOccurs="0" name="X1" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:PoolRuleFunction:- +++++++++++ -->
    <xs:simpleType name="PoolRuleFunction">
        <xs:annotation>
            <xs:documentation>
                The available pool rule functions.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Observe any x1 targets."/>
            <xs:enumeration value="Observe any x1 days."/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:ProposalConstraints:- +++++++++++ -->
    <xs:complexType name="Phase1Info">
        <xs:annotation>
            <xs:documentation>
                Relevant information which was provided in the Phase 1
                proposal.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="ObservingConditions">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element minOccurs="0" name="Moon" type="Moon"/>
                        <xs:element name="Transparency" type="Transparency"/>
                        <xs:element name="MaximumSeeing" type="SeeingValue"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="Instruments">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element maxOccurs="unbounded" minOccurs="0" name="Instrument">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="InstrumentMode" type="xs:string"/>
                                    <xs:element name="DetectorMode" type="xs:string"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element minOccurs="0" name="InstrumentSimulations">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element maxOccurs="unbounded" name="InstrumentSimulation" type="InstrumentSimulation"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="TimeCritical" type="xs:boolean"/>
            <xs:element name="TargetOfOpportunity" type="xs:boolean"/>
            <xs:element name="Priority4Proposal" type="xs:boolean"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:TimeAllocation:- +++++++++++ -->
    <xs:complexType name="TimeAllocation">
        <xs:annotation>
            <xs:documentation>
                The time allocated by the TACs for the various priorities.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Priority" type="Priority"/>
            <xs:element name="Moon" type="Moon"/>
            <xs:element name="AllocatedTime" type="ExposureTime"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:TimeTransfer:- +++++++++++ -->
    <xs:complexType name="TimeTransfer">
        <xs:annotation>
            <xs:documentation>
                A time transfer between observing conditions.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="From">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Priority" type="Priority"/>
                        <xs:element name="Moon" type="Moon"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="To">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Priority" type="Priority"/>
                        <xs:element name="Moon" type="Moon"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="Amount" type="ExposureTime"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:BlockVisit:- +++++++++++ -->
    <xs:complexType name="BlockVisit">
        <xs:annotation>
            <xs:documentation>
                An observation performed already for a block.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="BlockCode" type="xs:string"/>
            <xs:element name="BlockVisitStatus" type="BlockVisitStatus"/>
            <xs:element name="Priority" type="Priority"/>
            <xs:element name="Moon" type="Moon"/>
            <xs:element name="TotalTime" type="ExposureTime"/>
            <xs:element name="OverheadTime" type="ExposureTime"/>
            <xs:element minOccurs="0" name="PoolCode" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:BlockVisitStatus:- +++++++++++ -->
    <xs:simpleType name="BlockVisitStatus">
        <xs:annotation>
            <xs:documentation>
                The status of a block visit.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Accepted"/>
            <xs:enumeration value="Deleted"/>
            <xs:enumeration value="In queue"/>
            <xs:enumeration value="Rejected"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:BlockCode:- +++++++++++ -->
    <xs:complexType name="BlockCode">
        <xs:annotation>
            <xs:documentation>
                A server assigned unique id and the corresponding unique PIPT assigned id.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="ServerBlockCode" type="xs:string"/>
            <xs:element name="PiptBlockCode" type="xs:string"/>
            <xs:element name="Locked" type="xs:boolean"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Detail:- +++++++++++ -->
    <xs:complexType name="DetailInformation">
        <xs:annotation>
            <xs:documentation>
                Records which elements are used.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element default="false" name="ShowObservation" type="xs:boolean"/>
            <xs:element default="false" name="ShowTelescopeConfig" type="xs:boolean"/>
            <xs:element default="false" name="ShowPayloadConfig" type="xs:boolean"/>
            <xs:element default="false" name="ShowSubBlock" type="xs:boolean"/>
            <xs:element default="false" name="ShowSubSubBlock" type="xs:boolean"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== SHARED PROPOSAL DETAILS =========== -->

    <!-- +++++++++++ -:ProposalType:- +++++++++++ -->
    <xs:simpleType name="ProposalType">
        <xs:annotation>
            <xs:documentation>
                The type of proposal (science, commissioning or director's discretionary time).
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Commissioning"/>
            <xs:enumeration value="Director's Discretionary Time"/>
            <xs:enumeration value="Engineering"/>
            <xs:enumeration value="Gravitational Wave Event"/>
            <xs:enumeration value="Key Science Project"/>
            <xs:enumeration value="Large Science"/>
            <xs:enumeration value="OPTICON-Radionet Pilot"/>
            <xs:enumeration value="Phase 1 Test"/>
            <xs:enumeration value="Phase 2 Test"/>
            <xs:enumeration value="Science"/>
            <xs:enumeration value="Science Verification"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:Investigators:- +++++++++++ -->
    <xs:complexType name="Investigators">
        <xs:sequence>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="Investigator" type="Investigator">
                <xs:annotation>
                    <xs:documentation>The investigators associated with this proposal.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Investigator:- +++++++++++ -->
    <xs:complexType name="Investigator">
        <xs:all>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Surname" type="xs:string"/>
            <xs:element name="PartnerRef" type="xs:string"/>
            <xs:element name="Institute" type="Institute"/>
            <xs:element name="Email" type="xs:anyURI"/>
            <xs:element minOccurs="0" name="Phone" type="xs:string"/>
            <xs:element minOccurs="0" name="RelatedThesis" type="RelatedThesis"/>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:Partners:- +++++++++++ -->
    <xs:complexType name="Partners">
        <xs:sequence>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="Partner" type="Partner">
                <xs:annotation>
                    <xs:documentation>The SALT partners associated with this proposal.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Partner:- +++++++++++ -->
    <xs:complexType name="Partner">
        <xs:sequence>
            <xs:element default="South Africa" name="Name" type="PartnerName"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="TimeDistribution">
                <xs:annotation>
                    <xs:documentation>The percentage of the total required time to be charged to this SALT
                        partner.
                    </xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:all>
                        <xs:element name="Year" type="xs:unsignedInt"/>
                        <xs:element name="Semester">
                            <xs:simpleType>
                                <xs:annotation>
                                    <xs:documentation>
                                        The semester.

                                        1: 1 May to 31 October
                                        2: 1 November to 30 April
                                    </xs:documentation>
                                </xs:annotation>
                                <xs:restriction base="xs:unsignedInt">
                                    <xs:enumeration value="1"/>
                                    <xs:enumeration value="2"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element name="Value">
                            <xs:simpleType>
                                <xs:restriction base="xs:unsignedInt">
                                    <xs:minInclusive value="0"/>
                                    <xs:maxInclusive value="100"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element fixed="%" name="Units" type="xs:string"/>
                    </xs:all>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="id" type="xs:string" use="required"/>
    </xs:complexType>

    <!-- +++++++++++ -:PartnerName:- +++++++++++ -->
    <xs:simpleType name="PartnerName">
        <xs:annotation>
            <xs:documentation>The name of the SALT partner.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="South Africa"/>
            <xs:enumeration value="Poland"/>
            <xs:enumeration value="Georg-August-Universität Göttingen"/>
            <xs:enumeration value="Rutgers University"/>
            <xs:enumeration value="University of Canterbury"/>
            <xs:enumeration value="University of Wisconsin-Madison"/>
            <xs:enumeration value="Dartmouth College"/>
            <xs:enumeration value="UK SALT Consortium"/>
            <xs:enumeration value="University of North Carolina - Chapel Hill"/>
            <xs:enumeration value="Carnegie Mellon University"/>
            <xs:enumeration value="Hobby Eberly Telescope Board"/>
            <xs:enumeration value="American Museum of Natural History"/>
            <xs:enumeration value="Inter-University Centre for Astronomy &amp; Astrophysics"/>
            <xs:enumeration value="Durham University"/>
            <xs:enumeration value="Other"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:Institute:- +++++++++++ -->
    <xs:complexType name="Institute">
        <xs:sequence>
            <xs:element name="Name" type="xs:string">
                <xs:annotation>
                    <xs:documentation>The name of the institute.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element minOccurs="0" name="Department" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:HasAfricanPI:- +++++++++++ -->
    <xs:simpleType name="HasAfricanPI">
        <xs:annotation>
            <xs:documentation>
                Indicates that the PI for the proposal is affiliated to an
                African institution (outside South Africa).
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value=""/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:ScientificJustification:- +++++++++++ -->
    <xs:complexType name="ScientificJustification">
        <xs:annotation>
            <xs:documentation>
                The file path to the (external) PDF version of the scientific justification.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Path" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RelatedThesis:- +++++++++++ -->
    <xs:complexType name="RelatedThesis">
        <xs:annotation>
            <xs:documentation>
                A thesis which this proposal will form part of.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="TypeOfDegree" type="TypeOfDegree">
                <xs:annotation>
                    <xs:documentation>
                        The type of degree awarded for the thesis.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="YearOfCompletion">
                <xs:annotation>
                    <xs:documentation>
                        The expected year of completion for the thesis.
                    </xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="2006"/>
                        <xs:maxInclusive value="2100"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element minOccurs="0" name="ImportanceForThesis" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        A brief description of the importance and contribution to the thesis as well as the implication
                        if the data are not obtained in time.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:TypeOfDegree:- +++++++++++ -->
    <xs:simpleType name="TypeOfDegree">
        <xs:annotation>
            <xs:documentation>
                The type of degree awarded for a thesis which this proposal
                forms part of.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Masters"/>
            <xs:enumeration value="PhD"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:ExternalFunding:- +++++++++++ -->
    <xs:complexType name="ExternalFunding">
        <xs:annotation>
            <xs:documentation>
                This element contains the source of funding, if the proposal
                is made possible by external support.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="SourceOfFunding" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:PreviousProposal:- +++++++++++ -->
    <xs:complexType name="PreviousProposal">
        <xs:annotation>
            <xs:documentation>
                The status of a previous proposal.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Code" type="ProposalCode"/>
            <xs:element minOccurs="0" name="Title" type="xs:string"/>
            <xs:element name="Status" type="xs:string"/>
            <xs:element minOccurs="0" name="AllocatedTime" type="ExposureTime"/>
            <xs:element minOccurs="0" name="ObservedTime" type="ExposureTime"/>
            <xs:element minOccurs="0" name="Publications" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        SALT-related refereed publications based on the previous proposal, as a list of ADS bibcodes.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Targets:- +++++++++++ -->
    <xs:complexType name="Targets">
        <xs:annotation>
            <xs:documentation>
                The list of targets.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" name="Target" type="Target"/>
            <xs:element name="NumberOfOptionalTargets" type="xs:unsignedInt">
                <xs:annotation>
                    <xs:documentation>
                        The number of optional targets requested to be observed.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Target:- +++++++++++ -->
    <xs:complexType name="Target">
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="TargetCode" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        A unique string identifying the target.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TargetType" type="TargetType"/>
            <xs:choice>
                <xs:element name="Coordinates" type="Coordinates"/>
                <xs:element name="CoordinatesTable" type="CoordinatesTable"/>
                <xs:element name="HorizonsEphemerides" type="HorizonsEphemerides"/>
                <xs:element name="DummyTarget">
                    <xs:simpleType>
                        <xs:restriction base="xs:string">
                            <xs:enumeration value=""/>
                        </xs:restriction>
                    </xs:simpleType>
                </xs:element>
            </xs:choice>
            <xs:element name="MagnitudeRange" type="MagnitudeRange"/>
            <xs:element minOccurs="0" name="PeriodicTargetEphemeris" type="PeriodicTargetEphemeris"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="FindingChart" type="FindingChart"/>
            <xs:element name="Mandatory" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation>
                        Flag indicating whether the target is mandatory (true)
                        or optional (false).
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="id" type="xs:string" use="required"/>
    </xs:complexType>

    <!-- +++++++++++ -:MagnitudeRange:- +++++++++++ -->
    <xs:complexType name="MagnitudeRange">
        <xs:annotation>
            <xs:documentation>
                A magnitude range.
            </xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Bandpass" type="Bandpass"/>
            <xs:element name="Minimum">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0.0"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Maximum">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0.0"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:Bandpass:- +++++++++++ -->
    <xs:simpleType name="Bandpass">
        <xs:annotation>
            <xs:documentation>
                The bandpass for the magnitude range.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="U"/>
            <xs:enumeration value="B"/>
            <xs:enumeration value="V"/>
            <xs:enumeration value="R"/>
            <xs:enumeration value="I"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:Ephemeris:- +++++++++++ -->
    <xs:complexType name="PeriodicTargetEphemeris">
        <xs:all>
            <xs:element name="TimeZero">
                <xs:annotation>
                    <xs:documentation>
                        A time when the period begins. The available time bases are

                        BJD: Baryocentric Julian Date
                        HJD: Heliocentric Julian Date
                        JD: Julian Date
                    </xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:all>
                        <xs:element name="TimeValue">
                            <xs:simpleType>
                                <xs:restriction base="xs:double">
                                    <xs:minExclusive value="0"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element name="TimeBase" type="TimeBase">
                        </xs:element>
                    </xs:all>
                </xs:complexType>
            </xs:element>
            <xs:element name="Period">
                <xs:complexType>
                    <xs:all>
                        <xs:element name="Value">
                            <xs:simpleType>
                                <xs:restriction base="xs:double">
                                    <xs:minExclusive value="0"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element fixed="days" name="Units" type="xs:string"/>
                    </xs:all>
                </xs:complexType>
            </xs:element>
            <xs:element minOccurs="0" name="Pdot">
                <xs:complexType>
                    <xs:all>
                        <xs:element name="Value" type="xs:double"/>
                        <xs:element fixed="days/day" name="Units" type="xs:string"/>
                    </xs:all>
                </xs:complexType>
            </xs:element>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:TimeBase:- +++++++++++ -->
    <xs:simpleType name="TimeBase">
        <xs:annotation>
            <xs:documentation>
                The available time base values for the TimeZero element
                of a periodic target ephemeris. These are

                BJD: Baryocentric Julian date
                HJD: Heliocentric Julian date
                JD: Julian date
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="BJD"/>
            <xs:enumeration value="HJD"/>
            <xs:enumeration value="JD"/>
        </xs:restriction>
    </xs:simpleType>


    <!-- +++++++++++ -:FindingChart:- +++++++++++ -->
    <xs:complexType name="FindingChart">
        <xs:annotation>
            <xs:documentation>
                A finding chart.

                The finding chart can be specified as a path to an external file, as an image server to use for creating
                it automatically, as a URL to it, or by giving its MIME type and its content as a Base64 encoded string.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:choice>
                <xs:element name="Path" type="xs:string"/>
                <xs:element name="ImageServer" type="xs:string"/>
                <xs:element name="URL" type="xs:string"/>
                <xs:sequence>
                    <xs:element name="Content" type="xs:base64Binary"/>
                    <xs:element name="MimeType" type="xs:string"/>
                </xs:sequence>
            </xs:choice>
            <xs:element minOccurs="0" name="Comments" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Transparency:- +++++++++++ -->
    <xs:simpleType name="Transparency">
        <xs:annotation>
            <xs:documentation>
                Sky transparency.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Clear"/>
            <xs:enumeration value="Thin cloud"/>
            <xs:enumeration value="Thick cloud"/>
            <xs:enumeration value="Any"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:Moon:- +++++++++++ -->
    <xs:complexType name="MaximumLunarPhase">
        <xs:annotation>
            <xs:documentation>
                The maximum lunar phase allowed for this block.
            </xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Value">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0"/>
                        <xs:maxInclusive value="100"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="%" name="Units" type="xs:string"/>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:Moon:- +++++++++++ -->
    <xs:simpleType name="Moon">
        <xs:annotation>
            <xs:documentation>
                Sky brightness due to the Moon.

                Dark: Phase angle &gt; 135 degrees, or Moon set
                Dark-Gray: Phase angle between 90 and 135 degrees
                Bright-Gray: Phase angle between 45 and 90 degrees
                Bright: Phase angle between 0 and 45 degrees
                Any: Any phase angle
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Dark"/>
            <xs:enumeration value="Gray"/>
            <xs:enumeration value="Bright"/>
            <xs:enumeration value="Any"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:SeeingValue:- +++++++++++ -->
    <xs:complexType name="SeeingValue">
        <xs:annotation>
            <xs:documentation>A seeing value.</xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Value">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minExclusive value="0"/>
                        <xs:maxInclusive value="9.0"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="arcseconds" name="Units" type="xs:string"/>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:Ranking:- +++++++++++ -->
    <xs:simpleType name="Ranking">
        <xs:annotation>
            <xs:documentation>
                The ranking of an observation (for Phase 1) or of a block within
                the priority (for Phase 2).
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="High"/>
            <xs:enumeration value="Medium"/>
            <xs:enumeration value="Low"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:InstrumentSimulation:- +++++++++++ -->
    <xs:complexType name="InstrumentSimulation">
        <xs:annotation>
            <xs:documentation>
                An instrument simulation obtained with an instrument simulator.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Path" type="xs:string"/>
            <xs:element minOccurs="0" name="Comments" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Outreach:- +++++++++++ -->
    <xs:complexType name="Outreach">
        <xs:annotation>
            <xs:documentation>
                Details related to public outreach. These include a summary for the general
                public as well as a flag indicating whether the summary of the proposal may
                be displayed along with the all-sky camera image.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element minOccurs="0" name="Summary" type="xs:string"/>
            <xs:element name="AllowDisplaying" type="xs:boolean"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:ProposalCode:- +++++++++++ -->
    <xs:simpleType name="ProposalCode">
        <xs:restriction base="xs:string">
            <xs:pattern value="\d{4}-\d-[A-Z][A-Za-z]*(_[A-Z][A-Za-z]*)*-\d{3,}|ASYNC_\d+|Unsubmitted-\d+|Unknown"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- =========== SALTICAM PHASE 1 =========== -->

    <!-- +++++++++++ -:P1Salticam:- +++++++++++ -->
    <xs:complexType name="P1Salticam">
        <xs:annotation>
            <xs:documentation>A SALTICAM instrument configuration</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Filters">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element maxOccurs="unbounded" name="SalticamFilter">
                            <xs:annotation>
                                <xs:documentation>
                                    A Salticam filter. As a list of simple types causes problems for the PIPT,
                                    it is defined as a complex type with a Filter child element.
                                </xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="Filter" type="SalticamFilterName"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="DetMode" type="SalticamDetMode"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== SALTICAM PHASE 2 =========== -->

    <!-- +++++++++++ -:Salticam:- +++++++++++ -->
    <xs:complexType name="Salticam">
        <xs:annotation>
            <xs:documentation>A SALTICAM instrument configuration</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Cycles" type="Iterations"/>
            <xs:element name="SalticamProcedure" type="SalticamProcedure"/>
            <xs:element name="SalticamDetector" type="SalticamDetector"/>
            <xs:element name="MinimumSN" type="xs:unsignedInt">
                <xs:annotation>
                    <xs:documentation>Minimum signal-to-noise required.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element minOccurs="0" name="Dithering" type="Dithering"/>
            <xs:element name="InCalibration" type="xs:boolean"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="SalticamCalibration" type="SalticamCalibration"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="SalticamNonChargedCalibration" type="SalticamCalibration"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:SalticamDetector:- +++++++++++ -->
    <xs:complexType name="SalticamDetector">
        <xs:annotation>
            <xs:documentation>A Salticam Detector setup.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element default="Normal" name="DetMode" type="SalticamDetMode"/>
            <xs:element name="PreBinRows">
                <xs:annotation>
                    <xs:documentation>Combine this many CCD rows during readout</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                        <xs:maxInclusive value="9"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="PreBinCols">
                <xs:annotation>
                    <xs:documentation>Combine this many CCD columns during readout</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                        <xs:maxInclusive value="9"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element default="Science" name="ExposureType" type="SalticamExposureType"/>
            <xs:element name="Gain" type="SalticamGain"/>
            <xs:element name="ReadoutSpeed" type="SalticamReadoutSpeed"/>
            <xs:element default="1" name="Iterations" type="Iterations"/>
            <xs:element maxOccurs="42" minOccurs="0" name="Window">
                <xs:annotation>
                    <xs:documentation>Defines up to 42 CCD windows, used to restrict readout rows and columns
                        <ul>
                            <li>CentreRA - Right ascension for the window centre</li>
                            <li>CentreDec - Declination of the window centre</li>
                            <li>Width - Width of the window in arcseconds</li>
                            <li>NRows - Height of the window in arcseconds</li>
                        </ul>
                    </xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:all>
                        <xs:element name="CentreRA" type="RightAscension"/>
                        <xs:element name="CentreDec" type="Declination"/>
                        <xs:element name="Width">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="Value">
                                        <xs:simpleType>
                                            <xs:restriction base="xs:unsignedInt">
                                                <xs:minExclusive value="0"/>
                                            </xs:restriction>
                                        </xs:simpleType>
                                    </xs:element>
                                    <xs:element fixed="arcseconds" name="Units" type="xs:string"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="Height">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="Value">
                                        <xs:simpleType>
                                            <xs:restriction base="xs:unsignedInt">
                                                <xs:minExclusive value="0"/>
                                            </xs:restriction>
                                        </xs:simpleType>
                                    </xs:element>
                                    <xs:element fixed="arcseconds" name="Units" type="xs:string"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:all>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:SalticamExposureType:- +++++++++++ -->
    <xs:simpleType name="SalticamExposureType">
        <xs:annotation>
            <xs:documentation>Type of exposure to be made
                <ul>
                    <li>Science - Science exposure</li>
                    <li>Bias - Bias exposure.</li>
                    <li>Flat Field - Flat field exposure.</li>
                </ul>
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Bias"/>
            <xs:enumeration value="Flat Field"/>
            <xs:enumeration value="Science"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:SalticamGain:- +++++++++++ -->
    <xs:simpleType name="SalticamGain">
        <xs:annotation>
            <xs:documentation>This sets the amplifier gain for the CCD readout amplifiers.
                <ul>
                    <li>Faint - high gain for faint objects.</li>
                    <li>Bright - low gain for bright objects.</li>
                </ul>
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Faint"/>
            <xs:enumeration value="Bright"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:SalticamReadoutSpeed:- +++++++++++ -->
    <xs:simpleType name="SalticamReadoutSpeed">
        <xs:annotation>
            <xs:documentation>Sets the readout speed. Faster readouts have more noise.
                <ul>
                    <li>None - don't do a readout.</li>
                    <li>Slow - do a low noise, slow readout.</li>
                    <li>Fast - do a higher noise, faster readout.</li>
                </ul>
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="None"/>
            <xs:enumeration value="Slow"/>
            <xs:enumeration value="Fast"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:SalticamProcedure:- +++++++++++ -->
    <xs:complexType name="SalticamProcedure">
        <xs:annotation>
            <xs:documentation>This specifies the way the instrument is operated.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" name="SalticamFilterArray" type="SalticamFilterArray"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:SalticamFilterArray:- +++++++++++ -->
    <xs:complexType name="SalticamFilterArray">
        <xs:annotation>
            <xs:documentation>An array of SALTICAM filters to be used in sequence as listed with
                associated exposure times.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Filter" type="SalticamFilterName"/>
            <xs:element name="ExposureTime" type="ExposureTime"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:SalticamCalibration:- +++++++++++ -->
    <xs:complexType name="SalticamCalibration">
        <xs:annotation>
            <xs:documentation>
                A Salticam calibration defined within a Salticam configuration.
            </xs:documentation>
        </xs:annotation>
        <xs:choice>
            <xs:element name="SalticamBias">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Iterations" type="Iterations"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="SalticamCalibrationFlat">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="CalibrationFlatLamp" type="SalticamCalibrationFlatLamp"/>
                        <xs:element name="CalibrationFlatExposureTime" type="ExposureTime"/>
                        <xs:element name="Iterations" type="Iterations"/>
                        <xs:element name="CalibrationFlatRequirement" type="SalticamCalibrationFlatRequirement"/>
                        <xs:element minOccurs="0" name="CalibrationFlatCycleInterval">
                            <xs:annotation>
                                <xs:documentation>
                                    The number of cycles between two flats. This element should only be used if
                                    "Every N Cycles" is chosen as the flat requirement.
                                </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                                <xs:restriction base="xs:unsignedInt">
                                    <xs:minInclusive value="1"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="SalticamImagingFlat">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Type" type="SalticamMorningFlatType"/>
                        <xs:element name="Iterations" type="Iterations"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:choice>
    </xs:complexType>

    <!-- +++++++++++ -:SalticamCalibrationFlatLamp:- +++++++++++ -->
    <xs:simpleType name="SalticamCalibrationFlatLamp">
        <xs:annotation>
            <xs:documentation>
                Calibration flat lamps.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="QTH1"/>
            <xs:enumeration value="QTH2"/>
            <xs:enumeration value="QTH1 and QTH2"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:SalticamCalibrationFlatRequirement:- +++++++++++ -->
    <xs:simpleType name="SalticamCalibrationFlatRequirement">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Before science"/>
            <xs:enumeration value="After science"/>
            <xs:enumeration value="Before and after science"/>
            <xs:enumeration value="Every N cycles"/>
            <xs:enumeration value="Never"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:SalticamMorningFlatType:- +++++++++++ -->
    <xs:simpleType name="SalticamMorningFlatType">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Lamp"/>
            <xs:enumeration value="Sky"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:SalticamCalibrationSetup:- +++++++++++ -->
    <xs:complexType name="SalticamCalibrationSetup">
        <xs:annotation>
            <xs:documentation>A Salticam calibration setup defined outside a Salticam setup.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" name="Salticam" type="Salticam"/>
            <xs:element name="SalticamCalibration" type="SalticamCalibration"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== SALTICAM SHARED =========== -->

    <!-- +++++++++++ -:SalticamDetMode:- +++++++++++ -->
    <xs:simpleType name="SalticamDetMode">
        <xs:annotation>
            <xs:documentation>Describes the readout modes</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Normal"/>
            <xs:enumeration value="Frame Transfer"/>
            <xs:enumeration value="Slot Mode"/>
            <xs:enumeration value="Drift Scan"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- =========== RSS PHASE 1 =========== -->

    <!-- +++++++++++ -:P1Rss:- +++++++++++ -->
    <xs:complexType name="P1Rss">
        <xs:annotation>
            <xs:documentation>An RSS instrument configuration</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="SlitMask" type="P1RssSlitMask"/>
            <xs:element name="Mode" type="P1RssMode"/>
            <xs:element default="Normal" name="DetMode" type="RssDetMode"/>
            <xs:element minOccurs="0" name="Polarimetry">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="PolarimetryType" type="P1RssPolarimetryType"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:P1RssMode:- +++++++++++ -->
    <xs:complexType name="P1RssMode">
        <xs:annotation>
            <xs:documentation>The observing mode.</xs:documentation>
        </xs:annotation>
        <xs:choice>
            <xs:element name="Imaging" type="P1RssImaging"/>
            <xs:element name="Spectroscopy" type="P1RssSpectroscopy"/>
            <xs:element name="FabryPerot" type="P1RssFabryPerot"/>
        </xs:choice>
    </xs:complexType>

    <!-- +++++++++++ -:P1RssImaging:- +++++++++++ -->
    <xs:complexType name="P1RssImaging">
        <xs:annotation>
            <xs:documentation>An imaging setup.</xs:documentation>
        </xs:annotation>
    </xs:complexType>

    <!-- +++++++++++ -:P1RssSpectroscopy:- +++++++++++ -->
    <xs:complexType name="P1RssSpectroscopy">
        <xs:annotation>
            <xs:documentation>A spectroscopy setup.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Grating" type="RssGrating"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:P1RssSlitMask:- +++++++++++ -->
    <xs:complexType name="P1RssSlitMask">
        <xs:annotation>
            <xs:documentation>
                Different options are available for the slitmask:
                - Longslit: a slit from a predefined list of longslits
                - MOS (Multi object spectroscopy): a slit mask id and a PSMF file
            </xs:documentation>
        </xs:annotation>
        <xs:choice minOccurs="0">
            <xs:element name="PredefinedMask" type="P1RssPredefinedMask"/>
            <xs:element name="MOS">
                <xs:complexType>
                    <xs:sequence>
                        <!-- A description of the slit mask. -->
                        <xs:element name="Description" type="xs:string"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:choice>
    </xs:complexType>

    <!-- +++++++++++ -:P1RssPredefinedMask:- +++++++++++ -->
    <xs:complexType name="P1RssPredefinedMask">
        <xs:annotation>
            <xs:documentation>
                A predefined slit mask, such as a longslit.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="MaskType" type="P1RssPredefinedMaskType"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:P1RssPredefined Mask Type:- +++++++++++ -->
    <xs:simpleType name="P1RssPredefinedMaskType">
        <xs:annotation>
            <xs:documentation>
                The type of a predefined slit mask.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Longslit"/>
            <xs:enumeration value="Polarimetric"/>
            <xs:enumeration value="Slit Mask IFU"/>
            <xs:enumeration value="Calibration"/>
            <xs:enumeration value="Imaging"/>
            <xs:enumeration value="Coronographic"/>
            <xs:enumeration value="Highspeed"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:P1RssFabryPerot:- +++++++++++ -->
    <xs:complexType name="P1RssFabryPerot">
        <xs:annotation>
            <xs:documentation>
                A Fabry-Perot setup.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="FabryPerotMode" type="RssFabryPerotMode"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:P1RssPolarimetryType:- +++++++++++ -->
    <xs:simpleType name="P1RssPolarimetryType">
        <xs:annotation>
            <xs:documentation>
                The polarimetry types.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Linear"/>
            <xs:enumeration value="Linear Hi"/>
            <xs:enumeration value="Circular"/>
            <xs:enumeration value="Circular Hi"/>
            <xs:enumeration value="All Stokes"/>
            <xs:enumeration value="User Defined"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- =========== RSS PHASE 2 =========== -->

    <!-- +++++++++++ -:Rss:- +++++++++++ -->
    <xs:complexType name="Rss">
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element minOccurs="0" name="RssProcedure" type="RssProcedure"/>
            <xs:element name="RssConfig" type="RssConfig">
                <xs:annotation>
                    <xs:documentation>This describes the mechanical configuration of the instrument
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="RssDetector" type="RssDetector">
                <xs:annotation>
                    <xs:documentation>This specifies the exposure for the detector controller
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="MinimumSN" type="xs:unsignedInt">
                <xs:annotation>
                    <xs:documentation>Minimum signal-to-noise required.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Cycles" type="Iterations"/>
            <xs:element minOccurs="0" name="Dithering" type="Dithering"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="RssCalibration" type="RssCalibration"/>
            <xs:element minOccurs="0" name="UseNoArc" type="xs:boolean"/>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="RssNonChargedCalibration" type="RssCalibration"/>
            <xs:element name="InCalibration" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation>This states whether the RSS setup is a (nighttime) calibration.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element minOccurs="0" name="EnableNonStandardSetup" type="xs:boolean"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssProcedure:- +++++++++++ -->
    <xs:complexType name="RssProcedure">
        <xs:annotation>
            <xs:documentation>
                An RSS procedure.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element minOccurs="0" name="WaveplatePattern" type="RssWaveplatePattern"/>
            <xs:element minOccurs="0" name="EtalonPattern" type="RssEtalonPattern"/>
            <xs:element minOccurs="0" name="FabryPerotCalibrationRegion" type="RssFabryPerotCalibrationRegion"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssConfig:- +++++++++++ -->
    <xs:complexType name="RssConfig">
        <xs:annotation>
            <xs:documentation>An RSS configuration.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="SlitMask" type="RssSlitMask">
                <xs:annotation>
                    <xs:documentation>Slitmask info.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Mode" type="RssMode"/>
            <xs:choice>
                <xs:element name="FilterId" type="RssFilterId"/>
                <xs:element name="SalticamFilter" type="SalticamFilterName"/>
            </xs:choice>
            <xs:element minOccurs="0" name="Polarimetry" type="RssPolarimetry"/>
            <xs:element name="FocusPosition">
                <xs:annotation>
                    <xs:documentation>The focus position in microns. This is referred to the home indicator
                        of the focus actuator in the camera.
                    </xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:all>
                        <xs:element default="1000" name="Value">
                            <xs:simpleType>
                                <xs:restriction base="xs:unsignedInt">
                                    <xs:minInclusive value="0"/>
                                    <xs:maxInclusive value="1600"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element fixed="microns" name="Units" type="xs:string"/>
                    </xs:all>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssMode:- +++++++++++ -->
    <xs:complexType name="RssMode">
        <xs:annotation>
            <xs:documentation>
                The mode for this setup and the corresponding instrument configuration such as (in case of polarimetry)
                the waveplate pattern.
            </xs:documentation>
        </xs:annotation>
        <xs:choice>
            <xs:element name="Imaging" type="RssImaging"/>
            <xs:element name="Spectroscopy" type="RssSpectroscopy"/>
            <xs:element name="FabryPerot" type="RssFabryPerot"/>
        </xs:choice>
    </xs:complexType>

    <!-- +++++++++++ -:RssImaging:- +++++++++++ -->
    <xs:complexType name="RssImaging">
        <xs:annotation>
            <xs:documentation>
                An RSS imaging configuration.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssSpectroscopy:- +++++++++++ -->
    <xs:complexType name="RssSpectroscopy">
        <xs:sequence>
            <xs:element name="Grating" type="RssGrating"/>
            <xs:element name="GratingAngle" type="RssGratingAngle"/>
            <xs:element name="ArtStation" type="RssArtStation"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssFabryPerot:- +++++++++++ -->
    <xs:complexType name="RssFabryPerot">
        <xs:annotation>
            <xs:documentation>
                An RSS Fabry-Perot configuration.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="FabryPerotMode" type="RssFabryPerotMode"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssPolarimetry:- +++++++++++ -->
    <xs:complexType name="RssPolarimetry">
        <xs:annotation>
            <xs:documentation>
                An RSS polarimetry configuration.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="BeamsplitterOrientation" type="RssBeamsplitterOrientation"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssBeamsplitterOrientation:- +++++++++++ -->
    <xs:simpleType name="RssBeamsplitterOrientation">
        <xs:annotation>
            <xs:documentation>
                The orientation of the beamsplitter, which can be either normal or parallel.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="normal"/>
            <xs:enumeration value="parallel"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssSlitMask:- +++++++++++ -->
    <xs:complexType name="RssSlitMask">
        <xs:annotation>
            <xs:documentation>
                Different options are available for the slitmask:
                - Longslit: a slit from a predefined list of longslits
                - MOS (Multi object spectroscopy): a slit mask id and a PSMF file
                - SMI (Slit Mask IFU): a slit mask IFU from a predefined list
            </xs:documentation>
        </xs:annotation>
        <xs:choice minOccurs="0">
            <xs:element name="PredefinedMask" type="RssPredefinedMask"/>
            <xs:element name="MOS">
                <xs:complexType>
                    <xs:sequence>
                        <!-- The file path to the slitmask file generated by the RSS slitmask tool. -->
                        <xs:element name="SlitMaskFile">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="Path" type="xs:string"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="SMI" type="RssSMI"/>
        </xs:choice>
    </xs:complexType>

    <!-- +++++++++++ -:RssPredefinedMask:- +++++++++++ -->
    <xs:complexType name="RssPredefinedMask">
        <xs:annotation>
            <xs:documentation>
                A predefined slit mask, such as a longslit.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Barcode" type="RssPredefinedMaskBarcode"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssSMI:- +++++++++++ -->
    <xs:complexType name="RssSMI">
        <xs:annotation>
            <xs:documentation>
                A slit mask IFU.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Barcode" type="RssPredefinedMaskBarcode"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssWaveplatePattern:- +++++++++++ -->
    <xs:complexType name="RssWaveplatePattern">
        <xs:annotation>
            <xs:documentation>
                A list of half and/or quarter waveplate stations.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" name="PatternStep">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element minOccurs="0" name="HWStation" type="RssWaveStation"/>
                        <xs:element minOccurs="0" name="QWStation" type="RssWaveStation"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssFabryPerotCalibrationRegion:- +++++++++++ -->
    <xs:complexType name="RssFabryPerotCalibrationRegion">
        <xs:annotation>
            <xs:documentation>
                A calibration region for Fabry-Perot.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="MinimumWavelength" type="RssEtalonWavelength"/>
            <xs:element name="MaximumWavelength" type="RssEtalonWavelength"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssDetector:- +++++++++++ -->
    <xs:complexType name="RssDetector">
        <xs:annotation>
            <xs:documentation>An RSS Detector setup.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element default="Normal" name="DetMode" type="RssDetMode"/>
            <xs:element name="Iterations" type="Iterations"/>
            <xs:element minOccurs="0" name="RssDetectorWindow">
                <xs:complexType>
                    <xs:annotation>
                        <xs:documentation>
                            CCD windowing as implemented by the RSS detector, requires a
                            height (FrameSize) for a window spanning the entire length of the CCD.
                        </xs:documentation>
                    </xs:annotation>
                    <xs:sequence>
                        <xs:element name="Height">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="Value">
                                        <xs:simpleType>
                                            <xs:restriction base="xs:unsignedInt">
                                                <xs:minExclusive value="0"/>
                                            </xs:restriction>
                                        </xs:simpleType>
                                    </xs:element>
                                    <xs:element fixed="arcseconds" name="Units" type="xs:string"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element default="0" name="PreShuffle">
                <xs:annotation>
                    <xs:documentation>Shuffles this many CCD rows before an exposure</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:maxInclusive value="4096"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element default="0" name="PostShuffle">
                <xs:annotation>
                    <xs:documentation>Shuffles this many CCD rows after an exposure</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:maxInclusive value="4096"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element default="2" name="PreBinRows">
                <xs:annotation>
                    <xs:documentation>Combine this many CCD rows during readout</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                        <xs:maxInclusive value="9"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element default="2" name="PreBinCols">
                <xs:annotation>
                    <xs:documentation>Combine this many CCD columns during readout</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                        <xs:maxInclusive value="9"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element default="true" name="Prepare" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation>States whether or not the CCD will be prepared for the next exposure
                        after readout - necessary for all CCD modes apart from shuffle.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element default="Science" name="ExposureType" type="RssExposureType"/>
            <xs:element name="ExposureTime" type="ExposureTime"/>
            <xs:element default="Faint" name="Gain" type="RssGain"/>
            <xs:element default="Slow" name="ReadoutSpeed" type="RssReadoutSpeed"/>
            <xs:element name="DetectorCalculation" type="RssDetectorCalculation"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:RssDetectorCalculation:- +++++++++++ -->
    <xs:simpleType name="RssDetectorCalculation">
        <xs:annotation>
            <xs:documentation>The RSS detector can do various calculations on an image.
                <ul>
                    <li>None - no calculation.</li>
                    <li>Aperture - compute the location of backlit slitmask apertures.</li>
                    <li>Star - compute the location of stars.</li>
                    <li>Peakup - centre stars onto slitmask apertures.</li>
                </ul>
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="None"/>
            <xs:enumeration value="Focus"/>
            <xs:enumeration value="Nod and shuffle"/>
            <xs:enumeration value="MOS mask calibration"/>
            <xs:enumeration value="MOS acquisition"/>
            <xs:enumeration value="MOS scan"/>
            <xs:enumeration value="Fabry-Perot ring radius"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssExposureType:- +++++++++++ -->
    <xs:simpleType name="RssExposureType">
        <xs:annotation>
            <xs:documentation>Type of exposure to be made
                <ul>
                    <li>Science - Science exposure.</li>
                    <li>Bias - Bias exposure.</li>
                    <li>Flat Field - Flat field exposure.</li>
                    <li>Arc - Wavelength calibration exposure using arc lamp.</li>
                    <li>Dark</li>
                </ul>
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Science"/>
            <xs:enumeration value="Bias"/>
            <xs:enumeration value="Flat Field"/>
            <xs:enumeration value="Arc"/>
            <xs:enumeration value="Dark"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssGain:- +++++++++++ -->
    <xs:simpleType name="RssGain">
        <xs:annotation>
            <xs:documentation>This sets the amplifier gain for the CCD readout amplifiers.
                <ul>
                    <li>Faint - high gain for faint objects.</li>
                    <li>Bright - low gain for bright objects.</li>
                </ul>
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Faint"/>
            <xs:enumeration value="Bright"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssReadoutSpeed:- +++++++++++ -->
    <xs:simpleType name="RssReadoutSpeed">
        <xs:annotation>
            <xs:documentation>The readout speed. Faster readouts have more noise.
                <ul>
                    <li>None - don't do a readout.</li>
                    <li>Slow - do a low noise, slow readout.</li>
                    <li>Fast - do a higher noise, faster readout.</li>
                </ul>
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="None"/>
            <xs:enumeration value="Slow"/>
            <xs:enumeration value="Fast"/>
        </xs:restriction>
    </xs:simpleType>


    <!-- +++++++++++ -:RssWaveStation:- +++++++++++ -->
    <xs:simpleType name="RssWaveStation">
        <xs:restriction base="xs:string">
            <xs:enumeration value="0_0"/>
            <xs:enumeration value="1_11.25"/>
            <xs:enumeration value="2_22.50"/>
            <xs:enumeration value="3_33.75"/>
            <xs:enumeration value="4_45.00"/>
            <xs:enumeration value="5_56.25"/>
            <xs:enumeration value="6_67.50"/>
            <xs:enumeration value="7_78.75"/>
            <xs:enumeration value="8_90.00"/>
            <xs:enumeration value="9_101.25"/>
            <xs:enumeration value="10_112.50"/>
            <xs:enumeration value="11_123.75"/>
            <xs:enumeration value="12_135.00"/>
            <xs:enumeration value="13_146.25"/>
            <xs:enumeration value="14_157.50"/>
            <xs:enumeration value="15_168.75"/>
            <xs:enumeration value="16_180.00"/>
            <xs:enumeration value="17_191.25"/>
            <xs:enumeration value="18_202.50"/>
            <xs:enumeration value="19_213.75"/>
            <xs:enumeration value="20_225.00"/>
            <xs:enumeration value="21_236.25"/>
            <xs:enumeration value="22_247.50"/>
            <xs:enumeration value="23_258.75"/>
            <xs:enumeration value="24_270.00"/>
            <xs:enumeration value="25_281.25"/>
            <xs:enumeration value="26_292.50"/>
            <xs:enumeration value="27_303.75"/>
            <xs:enumeration value="28_315.00"/>
            <xs:enumeration value="29_326.25"/>
            <xs:enumeration value="30_337.50"/>
            <xs:enumeration value="31_348.75"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssCalibration:- +++++++++++ -->
    <xs:complexType name="RssCalibration">
        <xs:annotation>
            <xs:documentation>
                An RSS calibration defined within an RSS setup.
            </xs:documentation>
        </xs:annotation>
        <xs:choice>
            <xs:element name="RssArc">
                <xs:complexType>
                    <xs:sequence>
                        <xs:choice>
                            <xs:element name="UseDefaultArcLamp">
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value=""/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="ArcLamp" type="xs:string"/>
                        </xs:choice>
                        <xs:element name="ArcExposureTime" type="ExposureTime"/>
                        <xs:element name="Iterations" type="Iterations"/>
                        <xs:element name="ArcRequirement" type="RssArcRequirement"/>
                        <xs:element minOccurs="0" name="ArcCycleInterval">
                            <xs:annotation>
                                <xs:documentation>
                                    The number of cycles between two arcs. This element should only be used if
                                    "Every N Cycles" is chosen as the arc requirement.
                                </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                                <xs:restriction base="xs:unsignedInt">
                                    <xs:minInclusive value="1"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element name="DoneBetweenDitheringSteps" type="xs:boolean">
                            <xs:annotation>
                                <xs:documentation>
                                    Indicates whether this calibration shall be carried out between dithering
                                    steps. If the arc requirement the value of this element is ignored, as in
                                    this case the calibration needs to be done between dithering steps anyway.
                                </xs:documentation>
                            </xs:annotation>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="Ring">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="BetweenScans" type="xs:boolean"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="RssFabryPerotCalibration">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="BetweenScans" type="xs:boolean"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="RssBias">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Iterations" type="Iterations"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="RssCalibrationFlat">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="CalibrationFlatLamp" type="RssCalibrationFlatLamp"/>
                        <xs:element name="CalibrationFlatExposureTime" type="ExposureTime"/>
                        <xs:element name="Iterations" type="Iterations"/>
                        <xs:element name="CalibrationFlatRequirement" type="RssCalibrationFlatRequirement"/>
                        <xs:element minOccurs="0" name="CalibrationFlatCycleInterval">
                            <xs:annotation>
                                <xs:documentation>
                                    The number of cycles between two flats. This element should only be used if
                                    "Every N Cycles" is chosen as the flat requirement.
                                </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                                <xs:restriction base="xs:unsignedInt">
                                    <xs:minInclusive value="1"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="RssSpectroscopicFlat">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Type" type="RssMorningFlatType"/>
                        <xs:element name="Iterations" type="Iterations"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="RssImagingFlat">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Type" type="RssMorningFlatType"/>
                        <xs:element name="Iterations" type="Iterations"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="RssStandard">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="StandardType" type="RssStandardType"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:choice>
    </xs:complexType>

    <!-- +++++++++++ -:RssArcLamp:- +++++++++++ -->
    <xs:simpleType name="RssArcLamp">
        <xs:annotation>
            <xs:documentation>
                Arc lamps.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="CuAr"/>
            <xs:enumeration value="Xe"/>
            <xs:enumeration value="HgAr"/>
            <xs:enumeration value="Ne"/>
            <xs:enumeration value="Ar"/>
            <xs:enumeration value="ThAr"/>
            <xs:enumeration value="CuAr and Xe"/>
            <xs:enumeration value="HgAr and Ne"/>
            <xs:enumeration value="Ar and ThAr"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssArcRequirement:- +++++++++++ -->
    <xs:simpleType name="RssArcRequirement">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Before science"/>
            <xs:enumeration value="After science"/>
            <xs:enumeration value="Before and after science"/>
            <xs:enumeration value="Every N cycles"/>
            <xs:enumeration value="Never"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssCalibrationFlatLamp:- +++++++++++ -->
    <xs:simpleType name="RssCalibrationFlatLamp">
        <xs:annotation>
            <xs:documentation>
                Calibration flat lamps.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="QTH1"/>
            <xs:enumeration value="QTH2"/>
            <xs:enumeration value="QTH1 and QTH2"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssCalibrationFlatRequirement:- +++++++++++ -->
    <xs:simpleType name="RssCalibrationFlatRequirement">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Before science"/>
            <xs:enumeration value="After science"/>
            <xs:enumeration value="Before and after science"/>
            <xs:enumeration value="Every N cycles"/>
            <xs:enumeration value="Never"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssStandardType:- +++++++++++ -->
    <xs:simpleType name="RssStandardType">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Photometric"/>
            <xs:enumeration value="Spectroscopic"/>
            <xs:enumeration value="Spectrophotometric"/>
            <xs:enumeration value="RV"/>
            <xs:enumeration value="Linear polarimetric"/>
            <xs:enumeration value="Unpolarised"/>
            <xs:enumeration value="Smooth spectrum"/>
            <xs:enumeration value="Circular polarimetric"/>
            <xs:enumeration value="Lick"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssMorningFlatType:- +++++++++++ -->
    <xs:simpleType name="RssMorningFlatType">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Lamp"/>
            <xs:enumeration value="Sky"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RssCalibrationSetup:- +++++++++++ -->
    <xs:complexType name="RssCalibrationSetup">
        <xs:annotation>
            <xs:documentation>An RSS calibration setup defined outside an RSS setup.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" name="Rss" type="Rss"/>
            <xs:element name="RssCalibration" type="RssCalibration"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== RSS SHARED =========== -->


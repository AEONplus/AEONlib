    <!-- +++++++++++ -:Coordinates:- +++++++++++ -->
    <xs:complexType name="Coordinates">
        <xs:annotation>
            <xs:documentation>
                The coordinates of a target.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="RightAscension" type="RightAscension"/>
            <xs:element name="Declination" type="Declination"/>
            <xs:element minOccurs="0" name="ProperMotionAndEpoch" type="ProperMotionAndEpoch"/>
            <xs:element name="Equinox" type="xs:double"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Angle:- +++++++++++ -->
    <xs:simpleType name="Angle">
        <xs:annotation>
            <xs:documentation>
                An angle. A value for this type must start with a digit, optionally
                preceded by a plus or minus sign.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:pattern value="[+-]?\d+.*"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:ProperMotionAndEpoch:- +++++++++++ -->
    <xs:complexType name="ProperMotionAndEpoch">
        <xs:annotation>
            <xs:documentation>
                A proper motion of a target.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="RightAscensionDot" type="AngularSpeed"/>
            <xs:element name="DeclinationDot" type="AngularSpeed"/>
            <xs:element name="Epoch" type="xs:dateTime"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:CoordinatesTable:- +++++++++++ -->
    <xs:complexType name="CoordinatesTable">
        <xs:annotation>
            <xs:documentation>
                A path to a table containing the target coordinates.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Path" type="xs:string"/>
            <xs:element name="Tracking" type="Tracking"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:CoordinatesTable:- +++++++++++ -->
    <xs:complexType name="HorizonsEphemerides">
        <xs:annotation>
            <xs:documentation>
                Identifier and output interval to use for obtaining the
                ephemerides from NASA JPL's Horizons service.

                The identifier may either be an object name (such as "Ubuntu")
                or a designation (such as "2005 EW302").
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Identifier" type="xs:string"/>
            <xs:element name="OutputInterval">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Value">
                            <xs:simpleType>
                                <xs:restriction base="xs:unsignedInt">
                                    <xs:minInclusive value="1"/>
                                    <xs:maxInclusive value="1440"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element fixed="minutes" name="Units" type="xs:string"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="Tracking" type="Tracking"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Tracking:- +++++++++++ -->
    <xs:simpleType name="Tracking">
        <xs:annotation>
            <xs:documentation>
                Mode of tracking (sidereal or non-sidereal).
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Sidereal"/>
            <xs:enumeration value="Non-sidereal"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:RightAscension:- +++++++++++ -->
    <xs:complexType name="RightAscension">
        <xs:annotation>
            <xs:documentation>Equatorial Right Ascension of &lt;Target&gt;, measured in hours,
                minutes, and seconds. An optional proper motion may be included.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Hours">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="0"/>
                        <xs:maxInclusive value="23"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Minutes">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="0"/>
                        <xs:maxInclusive value="59"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Seconds">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0.0"/>
                        <xs:maxExclusive value="60"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Declination:- +++++++++++ -->
    <xs:complexType name="Declination">
        <xs:annotation>
            <xs:documentation>Container for the equatorial celestial coordinate of a Target in degrees,
                arcminutes and (decimal) arcseconds.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element default="-" name="Sign" type="Sign"/>
            <xs:element name="Degrees">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:maxInclusive value="90"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Arcminutes">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="0"/>
                        <xs:maxInclusive value="59"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Arcseconds">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0.0"/>
                        <xs:maxExclusive value="60"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:Sign:- +++++++++++ -->
    <xs:simpleType name="Sign">
        <xs:restriction base="xs:string">
            <xs:enumeration value="+"/>
            <xs:enumeration value="-"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:AngularSpeed:- +++++++++++ -->
    <xs:complexType name="AngularSpeed">
        <xs:all>
            <xs:element name="Value" type="xs:double"/>
            <xs:element fixed="arcseconds/year" name="Units" type="xs:string"/>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:ExposureTime:- +++++++++++ -->
    <xs:complexType name="ExposureTime">
        <xs:annotation>
            <xs:documentation>Exposure time in seconds</xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Value">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="seconds" name="Units" type="xs:string"/>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:SemesterExposureTime:- +++++++++++ -->
    <xs:complexType name="SemesterExposureTime">
        <xs:annotation>
            <xs:documentation>Exposure time in seconds for a semester.</xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Semester">
                <xs:annotation>
                    <xs:documentation>
                        The semester (relative to the semester for which the proposal is first
                        submitted). So if the proposal spans three semesters, the value may bw
                        1, 2 or 3.
                    </xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Value">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="seconds" name="Units" type="xs:string"/>
        </xs:all>
    </xs:complexType>

    <!-- +++++++++++ -:Iterations:- +++++++++++ -->
    <xs:simpleType name="Iterations">
        <xs:annotation>
            <xs:documentation>A number of iterations, i.e. a positive integer (which mustn't exceed the
                upper limit of xs:unsignedInt).
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:unsignedInt">
            <xs:minInclusive value="1"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:ScamFilter:- +++++++++++ -->
    <xs:simpleType name="SalticamFilterName">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Fused silica clear"/>
            <xs:enumeration value="Johnson U"/>
            <xs:enumeration value="Johnson B"/>
            <xs:enumeration value="Johnson V"/>
            <xs:enumeration value="Cousins R"/>
            <xs:enumeration value="Cousins I"/>
            <xs:enumeration value="380nm 40nm FWHM"/>
            <xs:enumeration value="SDSS u'"/>
            <xs:enumeration value="SDSS g'"/>
            <xs:enumeration value="SDSS r'"/>
            <xs:enumeration value="SDSS i'"/>
            <xs:enumeration value="SDSS z'"/>
            <xs:enumeration value="H-alpha"/>
            <xs:enumeration value="H-beta narrow"/>
            <xs:enumeration value="H-beta wide"/>
            <xs:enumeration value="Stroemgren u"/>
            <xs:enumeration value="Stroemgren v"/>
            <xs:enumeration value="Stroemgren b"/>
            <xs:enumeration value="Stroemgren y"/>
            <xs:enumeration value="SRE 1"/>
            <xs:enumeration value="SRE 2"/>
            <xs:enumeration value="SRE 3"/>
            <xs:enumeration value="SRE 4"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:Dithering:- +++++++++++ -->
    <xs:complexType name="Dithering">
        <xs:annotation>
            <xs:documentation>
                Dithering, characterized by the number of horizontal and vertical tiles, the number of
                dithering steps and the offset between steps (which is the same in both x and y direction).
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="HorizontalTileCount">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="VerticalTileCount">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="StepCount">
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Offset">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Value">
                            <xs:simpleType>
                                <xs:restriction base="xs:double">
                                    <xs:minExclusive value="0"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element fixed="arcseconds" name="Units" type="xs:string"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:IntendedFor:- +++++++++++ -->
    <xs:complexType name="IntendedFor">
        <xs:annotation>
            <xs:documentation>
                The year and semester for which a block is intended.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Year" type="xs:unsignedInt"/>
            <xs:element name="Semester" type="Semester"/>
        </xs:sequence>
    </xs:complexType>


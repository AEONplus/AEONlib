    <!-- +++++++++++ -:NirFilterId:- +++++++++++ -->
    <xs:simpleType name="NirFilterId">
        <xs:annotation>
            <xs:documentation>
                Barcode of the NIR filter.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="EMPTY"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirCameraFilterWheel:- +++++++++++ -->
    <xs:simpleType name="NirCameraFilterWheel">
        <xs:annotation>
            <xs:documentation>
                NIR camera filter wheel.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Block"/>
            <xs:enumeration value="Clear"/>
            <xs:enumeration value="Cutoff 1.5um"/>
            <xs:enumeration value="Cutoff 1.7um"/>
            <xs:enumeration value="Diffuser"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirBundleSeparation:- +++++++++++ -->
    <xs:simpleType name="NirBundleSeparation">
        <xs:annotation>
            <xs:documentation>
                Bundle separation in arcseconds.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:double">
            <xs:minInclusive value="54"/>
            <xs:maxInclusive value="165"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirConfig:- +++++++++++ -->
    <xs:complexType name="NirConfig">
        <xs:annotation>
            <xs:documentation>
                NIR configuration.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="FilterId" type="NirFilterId"/>
            <xs:element name="CameraFilterWheel" type="NirCameraFilterWheel"/>
            <xs:element name="Grating" type="NirGrating"/>
            <xs:element name="GratingAngle" type="NirGratingAngle"/>
            <xs:element name="ArtStation" type="NirArtStation"/>
            <xs:element name="BundleSeparation" type="NirBundleSeparation"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:NirDitherOffset:- +++++++++++ -->
    <xs:complexType name="NirDitherOffset">
        <xs:annotation>
            <xs:documentation>
                Dither offset, in image coordinates.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="X">
                <xs:simpleType>
                    <xs:annotation>
                        <xs:documentation>
                            Horizontal offset (in image coordinates) from the first
                            position, in milliarcseconds. Must be 0 for the first
                            dither step.
                        </xs:documentation>
                    </xs:annotation>
                    <xs:restriction base="xs:double">
                        <xs:maxInclusive value="100000"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="Y">
                <xs:simpleType>
                    <xs:annotation>
                        <xs:documentation>
                            Vertical offset (in image coordinates) from the first
                            position, in milliarcseconds. Must be 0 for the first
                            dither step.
                        </xs:documentation>
                    </xs:annotation>
                    <xs:restriction base="xs:double">
                        <xs:maxInclusive value="100000"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:NirDitherOffsetType:- +++++++++++ -->
    <xs:simpleType name="NirDitherOffsetType">
        <xs:annotation>
            <xs:documentation>
                Dither offset type.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Bundle Separation Offset"/>
            <xs:enumeration value="FIF Offset"/>
            <xs:enumeration value="Tracker Guided Offset"/>
            <xs:enumeration value="Unguided Offset"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirExposureType:- +++++++++++ -->
    <xs:simpleType name="NirExposureType">
        <xs:annotation>
            <xs:documentation>
                Exposure type.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Arc"/>
            <xs:enumeration value="Bias"/>
            <xs:enumeration value="Dark"/>
            <xs:enumeration value="Flat Field"/>
            <xs:enumeration value="Science"/>
            <xs:enumeration value="Sky"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirDitherStep:- +++++++++++ -->
    <xs:complexType name="NirDitherStep">
        <xs:annotation>
            <xs:documentation>
                Step in a dither pattern.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Offset" type="NirDitherOffset"/>
            <xs:element minOccurs="0" name="OffsetType" type="NirDitherOffsetType"/>
            <xs:element name="Detector" type="NirDetector"/>
            <xs:element name="ExposureType" type="NirExposureType"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:NirDitherPattern:- +++++++++++ -->
    <xs:complexType name="NirDitherPattern">
        <xs:annotation>
            <xs:documentation>
                A dither pattern.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" name="DitherStep" type="NirDitherStep"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:NirProcedureType:- +++++++++++ -->
    <xs:simpleType name="NirProcedureType">
        <xs:annotation>
            <xs:documentation>
                NIR procedure type.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Focus"/>
            <xs:enumeration value="Normal"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirProcedure:- +++++++++++ -->
    <xs:complexType name="NirProcedure">
        <xs:annotation>
            <xs:documentation>
                NIR procedure.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element default="Normal" name="ProcedureType" type="NirProcedureType"/>
            <xs:element name="DitherPattern" type="NirDitherPattern"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:NirArcRequirement:- +++++++++++ -->
    <xs:simpleType name="NirArcRequirement">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Before science"/>
            <xs:enumeration value="After science"/>
            <xs:enumeration value="Before and after science"/>
            <xs:enumeration value="Every N cycles"/>
            <xs:enumeration value="Never"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirArcLamp:- +++++++++++ -->
    <xs:simpleType name="NirArcLamp">
        <xs:annotation>
            <xs:documentation>
                Arc lamps.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Kr"/>
            <xs:enumeration value="Ar"/>
            <xs:enumeration value="Ne"/>
            <xs:enumeration value="Kr and Ar"/>
            <xs:enumeration value="Kr and Ne"/>
            <xs:enumeration value="Ar and Ne"/>
            <xs:enumeration value="Kr, Ar and Ne"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirArc:- +++++++++++ -->
    <xs:complexType name="NirArc">
        <xs:annotation>
            <xs:documentation>
                NIR arc setup.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:choice>
                <xs:element name="UseDefaultArcLamp">
                    <xs:simpleType>
                        <xs:restriction base="xs:string">
                            <xs:enumeration value=""/>
                        </xs:restriction>
                    </xs:simpleType>
                </xs:element>
                <xs:element name="ArcLamp" type="xs:string"/>
            </xs:choice>
            <xs:element minOccurs="0" name="ArcExposureTime" type="ExposureTime"/>
            <xs:element name="Iterations" type="Iterations"/>
            <xs:element name="ArcRequirement" type="NirArcRequirement"/>
            <xs:element minOccurs="0" name="ArcCycleInterval">
                <xs:annotation>
                    <xs:documentation>
                        The number of cycles between two arcs. This element should only be used if
                        "Every N Cycles" is chosen as the arc requirement.
                    </xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="DoneBetweenDitheringSteps" type="xs:boolean">
                <xs:annotation>
                    <xs:documentation>
                        Indicates whether this calibration shall be carried out between dithering
                        steps. If the arc requirement the value of this element is ignored, as in
                        this case the calibration needs to be done between dithering steps anyway.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:NirCalibrationFlatRequirement:- +++++++++++ -->
    <xs:simpleType name="NirCalibrationFlatRequirement">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Before science"/>
            <xs:enumeration value="After science"/>
            <xs:enumeration value="Before and after science"/>
            <xs:enumeration value="Every N cycles"/>
            <xs:enumeration value="Never"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirCalibrationFlatLamp:- +++++++++++ -->
    <xs:simpleType name="NirCalibrationFlatLamp">
        <xs:annotation>
            <xs:documentation>
                Calibration flat lamps.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="QTH"/>
            <xs:enumeration value="QTH1"/>
            <xs:enumeration value="QTH2"/>
            <xs:enumeration value="QTH1 and QTH2"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirCalibrationFlat:- +++++++++++ -->
    <xs:complexType name="NirCalibrationFlat">
        <xs:annotation>
            <xs:documentation>Calibration flat setup.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="CalibrationFlatLamp" type="NirCalibrationFlatLamp"/>
            <xs:element minOccurs="0" name="CalibrationFlatExposureTime" type="ExposureTime"/>
            <xs:element name="Iterations" type="Iterations"/>
            <xs:element name="CalibrationFlatRequirement" type="NirCalibrationFlatRequirement"/>
            <xs:element minOccurs="0" name="CalibrationFlatCycleInterval">
                <xs:annotation>
                    <xs:documentation>
                        The number of cycles between two flats. This element should only be used if
                        "Every N Cycles" is chosen as the flat requirement.
                    </xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:unsignedInt">
                        <xs:minInclusive value="1"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:NirCalibration:- +++++++++++ -->
    <xs:complexType name="NirCalibration">
        <xs:annotation>
            <xs:documentation>
                An NIR calibration.
            </xs:documentation>
        </xs:annotation>
        <xs:choice>
            <xs:element name="NirArc" type="NirArc"/>
            <xs:element name="NirCalibrationFlat" type="NirCalibrationFlat"/>
            <xs:element name="NirSpectroscopicArc">
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:enumeration value=""/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="NirSpectroscopicFlat">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Type" type="NirMorningFlatType"/>
                        <xs:element name="Iterations" type="Iterations"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="NirStandard">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="StandardType" type="NirStandardType"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:choice>
    </xs:complexType>

    <!-- +++++++++++ -:NirStandardType:- +++++++++++ -->
    <xs:simpleType name="NirStandardType">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Spectrophotometric"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirMorningFlatType:- +++++++++++ -->
    <xs:simpleType name="NirMorningFlatType">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Lamp"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:NirCalibrationSetup:- +++++++++++ -->
    <xs:complexType name="NirCalibrationSetup">
        <xs:annotation>
            <xs:documentation>
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Nir" type="Nir"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== NIRWALS SHARED =========== -->

    <!-- +++++++++++ -:NirGrating:- +++++++++++ -->
    <xs:simpleType name="NirGrating">
        <xs:annotation>
            <xs:documentation>
                NIR grating.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="ng0950"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- =========== BVIT PHASE 1 =========== -->

    <!-- +++++++++++ -:P1Bvit:- +++++++++++ -->
    <xs:complexType name="P1Bvit">
        <xs:annotation>
            <xs:documentation>
                A BVIT configuration.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Filter" type="BvitFilter"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== BVIT PHASE 2 =========== -->

    <!-- +++++++++++ -:Bvit:- +++++++++++ -->
    <xs:complexType name="Bvit">
        <xs:annotation>
            <xs:documentation>
                A BVIT setup.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="xs:string"/>
            <xs:element name="Mode" type="BvitMode"/>
            <xs:element name="Filter" type="BvitFilter"/>
            <xs:element name="NeutralDensityFilter" type="BvitNeutralDensityFilter"/>
            <xs:element name="IrisSize" type="BvitIrisSize"/>
            <xs:element name="ShutterOpenTime" type="ExposureTime"/>
            <xs:element name="ComparisonStarVMag" type="xs:double"/>
            <xs:element minOccurs="0" name="Dithering" type="Dithering"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:BvitMode:- +++++++++++ -->
    <xs:simpleType name="BvitMode">
        <xs:annotation>
            <xs:documentation>
                The operational mode. In imaging mode, a normal exposure is made.
                In streaming mode, each incoming photon is tagged with the arrival
                time.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Imaging"/>
            <xs:enumeration value="Streaming"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:BvitNeutralDensityFilter:- +++++++++++ -->
    <xs:simpleType name="BvitNeutralDensityFilter">
        <xs:annotation>
            <xs:documentation>
                The value x in the transmission factor 10^-x of the neutral density filter.
                For example, the value 0.3 means that the ratio I/I0 of the intensities I
                and I0 after and before passing the filter is I/I0=10^-0.3. The value "open"
                indicates that no neutral density filter is used.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Open"/>
            <xs:enumeration value="0.3"/>
            <xs:enumeration value="0.5"/>
            <xs:enumeration value="1.0"/>
            <xs:enumeration value="2.0"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- +++++++++++ -:BvitIrisSize:- +++++++++++ -->
    <xs:complexType name="BvitIrisSize">
        <xs:annotation>
            <xs:documentation>
                The iris size to use for the BVIT observation.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element fixed="25" name="Value" type="xs:double"/>
            <xs:element fixed="millimeters" name="Units" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <!-- +++++++++++ -:BvitCalibration:- +++++++++++ -->
    <xs:complexType name="BvitCalibration">
        <xs:annotation>
            <xs:documentation>A BVIT calibration.</xs:documentation>
        </xs:annotation>
    </xs:complexType>

    <!-- +++++++++++ -:BvitCalibrationSetup:- +++++++++++ -->
    <xs:complexType name="BvitCalibrationSetup">
        <xs:annotation>
            <xs:documentation>A BVIT calibration setup defined outside a BVIT setup.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element maxOccurs="unbounded" name="Bvit" type="Bvit"/>
            <xs:element name="BvitCalibration" type="BvitCalibration"/>
        </xs:sequence>
    </xs:complexType>

    <!-- =========== BVIT SHARED =========== -->

    <!-- +++++++++++ -:BvitFilter:- +++++++++++ -->
    <xs:simpleType name="BvitFilter">
        <xs:annotation>
            <xs:documentation>
                A BVIT filter. The value "Open" indicates that no filter is used.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Open"/>
            <xs:enumeration value="B"/>
            <xs:enumeration value="V"/>
            <xs:enumeration value="R"/>
            <xs:enumeration value="H-alpha"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- =========== SHARED =========== -->


    <!-- +++++++++++ -:RssGratingAngle:- +++++++++++ -->
    <xs:complexType name="RssGratingAngle">
        <xs:annotation>
            <xs:documentation>The grating can be rotated to any angle between 0 and 100 degrees. The
                angular choice is quantized only by the resolution of the stepper motor.
            </xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="Value">
                <xs:simpleType>
                    <xs:restriction base="xs:double">
                        <xs:minInclusive value="0"/>
                        <xs:maxInclusive value="100"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element fixed="degrees" name="Units" type="xs:string"/>
        </xs:all>
    </xs:complexType>

